<Window x:Class="PerformanceMonitorAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="Performance Monitor Analyzer" Height="800" Width="1200" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="550" MinHeight="100" MaxHeight="750"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <Menu Grid.Row="0">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="BLGファイルを開く(_O)..." Click="OpenBlgFile_Click"/>

                <Separator/>
                <MenuItem Header="終了(_X)" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="パターン(_P)">
                <MenuItem x:Name="PatternMenu" Header="カウンターパターンを適用(_A)">
                    <!-- パターンは動的に追加される -->
                </MenuItem>
                <Separator/>
                <MenuItem Header="パターン設定ファイルを開く(_O)..." Click="OpenPatternConfig_Click"/>
                <MenuItem Header="パターン設定を再読み込み(_R)" Click="ReloadPatternConfig_Click"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="バージョン情報(_A)"/>
            </MenuItem>
        </Menu>

        <!-- プログレスバー -->
        <Grid Grid.Row="1" x:Name="ProgressGrid" Visibility="Collapsed" Background="#F0F0F0" Margin="10,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" x:Name="ProgressStatusText" Text="ファイルを読み込み中..." 
                       Margin="10,10,10,5" FontWeight="Bold"/>
            <ProgressBar Grid.Row="1" x:Name="LoadingProgressBar" 
                         Height="20" Margin="10,0,10,10" 
                         IsIndeterminate="True"/>
        </Grid>

        <!-- 上部: カウンター選択とグラフ表示 -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- 左側: カウンター一覧 -->
            <GroupBox Grid.Column="0" Header="パフォーマンスカウンター" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ファイル名表示 -->
                    <TextBlock Grid.Row="0" x:Name="FileNameDisplay" 
                             Text="ファイルが選択されていません" 
                             Margin="5,5,5,5" 
                             FontWeight="Bold"
                             Foreground="DarkBlue"
                             TextWrapping="Wrap"/>
                    
                    <!-- コンピューター名表示 -->
                    <TextBlock Grid.Row="0" x:Name="ComputerNameDisplay" 
                             Text="" 
                             Margin="5,25,5,10" 
                             FontSize="11"
                             Foreground="DarkGray"
                             TextWrapping="Wrap"
                             Visibility="Collapsed"/>
                    
                    <!-- パターン選択 -->
                    <StackPanel Grid.Row="1" Margin="5,5,5,10">
                        <TextBlock Text="🎯 カウンターパターン:" 
                                 Margin="0,0,0,3" 
                                 FontWeight="SemiBold"/>
                        <ComboBox x:Name="PatternComboBox" 
                                DisplayMemberPath="Name"
                                SelectionChanged="PatternComboBox_SelectionChanged"
                                ToolTip="事前定義されたカウンターパターンを選択"/>
                        <Button x:Name="ApplyPatternButton" 
                              Content="パターンを適用" 
                              Margin="0,3,0,0" 
                              Click="ApplyPattern_Click"
                              IsEnabled="False"
                              ToolTip="選択されたパターンでカウンターを自動選択します"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="2" 
                             Text="📈 表示したいカウンターをチェック:" 
                             Margin="5,0,5,5" 
                             FontWeight="SemiBold"/>
                    
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <TreeView x:Name="CounterTreeView" Margin="5">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsChecked}" 
                                                IsThreeState="{Binding IsThreeState}"
                                                Checked="CounterCheckBox_Checked"
                                                Unchecked="CounterCheckBox_Unchecked"
                                                Indeterminate="CounterCheckBox_Indeterminate"
                                                Tag="{Binding}"
                                                Visibility="{Binding CheckBoxVisibility}"
                                                Margin="0,0,5,0"/>
                                        <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,3,0"/>
                                        <TextBlock Text="{Binding DisplayName}" 
                                                 Margin="0,0,0,0"
                                                 FontWeight="{Binding FontWeight}"
                                                 Foreground="{Binding TextColor}"/>
                                        <TextBlock Text="{Binding CountDisplay}" 
                                                 Margin="5,0,0,0" 
                                                 FontSize="10" 
                                                 Foreground="Gray"
                                                 Visibility="{Binding CountVisibility}"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>

                    <!-- 時間範囲選択 -->
                    <Expander Grid.Row="4" Header="📅 時間範囲選択" IsExpanded="False" Margin="5,5,5,0"
                             x:Name="TimeRangeExpander" Visibility="Collapsed">
                        <StackPanel Margin="10">
                            <TextBlock Text="時間範囲:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TimeRangeDisplay" Text="時間範囲が検出されていません" Margin="0,0,0,10" FontSize="11" Foreground="DarkGray"/>
                            
                            <Grid Margin="0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 開始時間スライダー -->
                                <StackPanel Grid.Row="0" Margin="0,0,0,5">
                                    <TextBlock Text="開始時間:" FontSize="11" Margin="0,0,0,2"/>
                                    <Slider x:Name="StartTimeSlider" 
                                           Minimum="0" Maximum="100" Value="0"
                                           ValueChanged="TimeSlider_ValueChanged"
                                           TickPlacement="BottomRight" TickFrequency="10"
                                           IsSnapToTickEnabled="False"/>
                                    <TextBlock x:Name="StartTimeText" Text="--:--:--" FontSize="10" HorizontalAlignment="Left" Foreground="DarkBlue"/>
                                </StackPanel>
                                
                                <!-- 終了時間スライダー -->
                                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                    <TextBlock Text="終了時間:" FontSize="11" Margin="0,0,0,2"/>
                                    <Slider x:Name="EndTimeSlider" 
                                           Minimum="0" Maximum="100" Value="100"
                                           ValueChanged="TimeSlider_ValueChanged"
                                           TickPlacement="BottomRight" TickFrequency="10"
                                           IsSnapToTickEnabled="False"/>
                                    <TextBlock x:Name="EndTimeText" Text="--:--:--" FontSize="10" HorizontalAlignment="Right" Foreground="DarkBlue"/>
                                </StackPanel>
                                
                                <!-- PDH API実行状況表示 -->
                                <Expander Grid.Row="2" Header="🔧 PDH API実行状況" IsExpanded="False" 
                                         Margin="0,10,0,0" x:Name="RelogStatusExpander" Visibility="Collapsed">
                                    <StackPanel Margin="5">
                                        <TextBlock Text="実行内容:" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                        <TextBox x:Name="RelogCommandDisplay" 
                                                IsReadOnly="True" 
                                                Background="LightYellow"
                                                FontFamily="Consolas"
                                                FontSize="10"
                                                TextWrapping="Wrap"
                                                MinHeight="40"
                                                Margin="0,0,0,10"
                                                VerticalScrollBarVisibility="Auto"/>
                                        
                                        <TextBlock Text="実行結果:" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                        <TextBox x:Name="RelogResultDisplay"
                                                IsReadOnly="True"
                                                Background="LightGray"
                                                FontFamily="Consolas"
                                                FontSize="10"
                                                TextWrapping="Wrap"
                                                MinHeight="60"
                                                VerticalScrollBarVisibility="Auto"/>
                                    </StackPanel>
                                </Expander>
                            </Grid>
                        </StackPanel>
                    </Expander>
                    
                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                        <Button Content="🚀 選択されたカウンターを読み込み" 
                               AutomationProperties.Name="選択されたカウンターを読み込み"
                               Click="ExecuteSelectedCounters_Click"
                               Background="LightBlue" 
                               Padding="8,4"
                               Margin="0,0,10,0"
                               IsEnabled="False"
                               x:Name="ExecuteButton"/>
                        <Button Content="すべて選択" Click="SelectAll_Click" Margin="0,0,5,0"/>
                        <Button Content="すべて解除" Click="UnselectAll_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- 中央: グラフ表示 -->
            <GroupBox Grid.Column="1" Header="グラフ表示" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- ScottPlot グラフコンテナ -->
                    <scottplot:WpfPlot x:Name="PerformanceChart" 
                                      Grid.Row="0"
                                      Background="White" />
                    
                    <!-- データなしの場合のメッセージ -->
                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                              x:Name="NoDataMessagePanel" 
                              Visibility="Visible">
                        <TextBlock x:Name="NoDataMessage" 
                                 Text="📊 BLGファイルを開いてカウンターを選択してください"
                                 HorizontalAlignment="Center"
                                 FontSize="16"
                                 Foreground="Gray"
                                 Margin="10"/>
                        <TextBlock HorizontalAlignment="Center" FontSize="12" Foreground="DarkGray" Margin="5">
                            <Run Text="💡 "/>
                            <Run Text="チェックボックス" FontWeight="Bold"/>
                            <Run Text=" または "/>
                            <Run Text="カウンター名" FontWeight="Bold"/>
                            <Run Text="をクリックして詳細データを表示"/>
                        </TextBlock>
                        <TextBlock Text="✨ グラフ機能が実装されました！"
                                 HorizontalAlignment="Center"
                                 FontSize="12"
                                 Foreground="DarkGreen"
                                 FontWeight="Bold"
                                 Margin="5"/>
                    </StackPanel>
                    
                    <!-- 統計情報表示エリア -->
                    <Border Grid.Row="1" x:Name="StatisticsBorder" 
                           Background="#F8F8F8" 
                           BorderBrush="#E0E0E0" 
                           BorderThickness="0,1,0,0" 
                           Margin="5,0,5,5"
                           Visibility="Collapsed">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- ヘッダー -->
                            <TextBlock Grid.Row="0" 
                                     Text="📊 選択カウンターの統計情報" 
                                     FontWeight="Bold" 
                                     FontSize="12"
                                     Foreground="DarkBlue"
                                     Margin="0,0,0,8"/>
                            
                            <!-- 統計情報テーブル -->
                            <ScrollViewer Grid.Row="1" 
                                        VerticalScrollBarVisibility="Auto" 
                                        HorizontalScrollBarVisibility="Auto"
                                        MaxHeight="150">
                                <DataGrid x:Name="StatisticsDataGrid"
                                        AutoGenerateColumns="False"
                                        IsReadOnly="True"
                                        HeadersVisibility="Column"
                                        GridLinesVisibility="Horizontal"
                                        Background="White"
                                        AlternatingRowBackground="#F9F9F9"
                                        BorderThickness="1"
                                        BorderBrush="#DDD"
                                        FontSize="11">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="カウンター名" Binding="{Binding CounterName}" Width="*" />
                                        <DataGridTextColumn Header="平均" Binding="{Binding Average}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#008000"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="最大" Binding="{Binding Maximum}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#B40000"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="最小" Binding="{Binding Minimum}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#0000B4"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </GroupBox>

            <!-- 右側: スケール設定 -->
            <GroupBox Grid.Column="2" Header="スケール設定" x:Name="ScaleControlGroupBox" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 説明テキスト -->
                    <TextBlock Grid.Row="0" Text="各カウンターのスケールを調整:"
                             FontSize="11" Foreground="DarkGray" 
                             Margin="5,5,5,10" TextWrapping="Wrap"/>
                    
                    <!-- カウンタースケール設定リスト -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="CounterScaleStackPanel" Margin="5">
                            <!-- カウンター別スケール設定が動的に追加される -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- GridSplitter: データテーブル領域の高さを動的に変更 -->
        <GridSplitter Grid.Row="3" 
                      Height="5" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch"
                      Background="#E0E0E0"
                      BorderBrush="#CCCCCC"
                      BorderThickness="0,1,0,1"
                      Cursor="SizeNS"
                      ShowsPreview="False"
                      ToolTip="ドラッグしてデータテーブル領域の高さを調整">
            <GridSplitter.Style>
                <Style TargetType="GridSplitter">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#D0D0D0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </GridSplitter.Style>
        </GridSplitter>

        <!-- 下部: データテーブルとログ表示 -->
        <Grid Grid.Row="4" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="700" MinWidth="150"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左側: データテーブル（タブ形式） -->
            <GroupBox Grid.Column="0" Header="📊 データテーブル">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- データテーブルの説明とコントロール -->
                    <Border Grid.Row="0" Margin="5" Background="#F8F8F8" Padding="5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,20,0">
                                <Run Text="📈 カウンター選択方法: "/>
                                <Run Text="チェックボックスをクリック" FontWeight="Bold" Foreground="DarkBlue"/>
                                <Run Text=" または "/>
                                <Run Text="カウンター名をクリック" FontWeight="Bold" Foreground="DarkGreen"/>
                            </TextBlock>
                            <Button Content="すべてのタブを閉じる" 
                                  Click="CloseAllTabs_Click" 
                                  Padding="8,2,8,2"
                                  Margin="0,0,10,0"/>
                            <Button Content="全データをCSV出力" 
                                  Click="ExportAllDataToCsv_Click" 
                                  Padding="8,2,8,2"/>
                        </StackPanel>
                    </Border>
                    
                    <TabControl x:Name="DataTabControl" Grid.Row="1">
                        <!-- データタブは動的に追加される -->
                    </TabControl>
                </Grid>
            </GroupBox>
            
            <!-- 垂直グリッドスプリッター -->
            <GridSplitter Grid.Column="1" 
                          Width="5" 
                          HorizontalAlignment="Stretch" 
                          VerticalAlignment="Stretch"
                          Background="#E0E0E0"
                          BorderBrush="#CCCCCC"
                          BorderThickness="1,0,1,0"
                          Cursor="SizeWE"
                          ShowsPreview="False"
                          ToolTip="ドラッグしてログ表示領域の幅を調整">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>
            
            <!-- 右側: ログ表示 -->
            <GroupBox Grid.Column="2" Header="📋 ログ表示">
                <TabControl x:Name="LogTabControl">
                    <!-- ログタブは動的に追加される -->
                </TabControl>
            </GroupBox>
        </Grid>
    </Grid>
</Window>