<Window x:Class="PerformanceMonitorAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Performance Monitor Analyzer" Height="800" Width="1200" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="300"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <Menu Grid.Row="0">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="BLGファイルを開く(_O)..." Click="OpenBlgFile_Click"/>
                <Separator/>
                <MenuItem Header="終了(_X)" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="バージョン情報(_A)"/>
            </MenuItem>
        </Menu>

        <!-- プログレスバー -->
        <Grid Grid.Row="1" x:Name="ProgressGrid" Visibility="Collapsed" Background="#F0F0F0" Margin="10,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" x:Name="ProgressStatusText" Text="ファイルを読み込み中..." 
                       Margin="10,10,10,5" FontWeight="Bold"/>
            <ProgressBar Grid.Row="1" x:Name="LoadingProgressBar" 
                         Height="20" Margin="10,0,10,10" 
                         IsIndeterminate="True"/>
        </Grid>

        <!-- 上部: カウンター選択とグラフ表示 -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側: カウンター一覧 -->
            <GroupBox Grid.Column="0" Header="パフォーマンスカウンター" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ファイル名表示 -->
                    <TextBlock Grid.Row="0" x:Name="FileNameDisplay" 
                             Text="ファイルが選択されていません" 
                             Margin="5,5,5,10" 
                             FontWeight="Bold"
                             Foreground="DarkBlue"
                             TextWrapping="Wrap"/>
                    
                    <TextBlock Grid.Row="1" Text="選択してグラフに表示:" Margin="5,0,5,5"/>
                    
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <TreeView x:Name="CounterTreeView" Margin="5">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsChecked}" 
                                                Checked="CounterCheckBox_Checked"
                                                Unchecked="CounterCheckBox_Unchecked"
                                                Tag="{Binding FullPath}"
                                                Visibility="{Binding CheckBoxVisibility}"/>
                                        <TextBlock Text="{Binding DisplayName}" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                        <Button Content="すべて選択" Click="SelectAll_Click" Margin="0,0,5,0"/>
                        <Button Content="すべて解除" Click="UnselectAll_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- 右側: グラフ表示 -->
            <GroupBox Grid.Column="1" Header="グラフ表示">
                <Grid>
                    <Grid x:Name="PerformanceChart" Background="White" />
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="NoDataMessage" 
                                 Text="BLGファイルを開いてカウンターを選択してください"
                                 HorizontalAlignment="Center"
                                 FontSize="16"
                                 Foreground="Gray"
                                 Margin="10"/>
                        <TextBlock Text="※グラフ機能は現在開発中です"
                                 HorizontalAlignment="Center"
                                 FontSize="12"
                                 Foreground="DarkGray"
                                 Margin="5"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- 下部: データテーブル（タブ形式） -->
        <GroupBox Grid.Row="3" Header="データテーブル" Margin="10,0,10,10">
            <TabControl x:Name="DataTabControl">
                <!-- タブは動的に追加される -->
            </TabControl>
        </GroupBox>
    </Grid>
</Window>