<Window x:Class="PerformanceMonitorAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="Performance Monitor Analyzer" Height="800" Width="1200" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="400" MinHeight="100" MaxHeight="750"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <Menu Grid.Row="0">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="BLGファイルを開く(_O)..." Click="OpenBlgFile_Click"/>

                <Separator/>
                <MenuItem Header="終了(_X)" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="パターン(_P)">
                <MenuItem x:Name="PatternMenu" Header="カウンターパターンを適用(_A)">
                    <!-- パターンは動的に追加される -->
                </MenuItem>
                <Separator/>
                <MenuItem Header="パターン設定ファイルを開く(_O)..." Click="OpenPatternConfig_Click"/>
                <MenuItem Header="パターン設定を再読み込み(_R)" Click="ReloadPatternConfig_Click"/>
            </MenuItem>
            <MenuItem Header="グラフ(_G)" x:Name="GraphMenu" IsEnabled="False">
                <MenuItem Header="グラフをクリップボードにコピー(_C)" Click="CopyGraphToClipboard_Click" InputGestureText="Ctrl+C"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="バージョン情報(_A)"/>
            </MenuItem>
        </Menu>

        <!-- プログレスバー -->
        <Grid Grid.Row="1" x:Name="ProgressGrid" Visibility="Collapsed" Background="#F0F0F0" Margin="10,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" x:Name="ProgressStatusText" Text="ファイルを読み込み中..." 
                       Margin="10,10,10,5" FontWeight="Bold"/>
            <ProgressBar Grid.Row="1" x:Name="LoadingProgressBar" 
                         Height="20" Margin="10,0,10,10" 
                         IsIndeterminate="True"/>
        </Grid>

        <!-- 上部: カウンター選択とグラフ表示 -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="CounterPanelColumn" Width="350" MinWidth="220"/>
                <ColumnDefinition x:Name="CounterPanelSplitterColumn" Width="22"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="ScalePanelSplitterColumn" Width="22"/>
                <ColumnDefinition x:Name="ScalePanelColumn" Width="230" MinWidth="210"/>
            </Grid.ColumnDefinitions>

            <!-- 左側: カウンター一覧 -->
            <GroupBox Grid.Column="0" x:Name="CounterPanelGroupBox" Header="パフォーマンスカウンター" Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ファイル名とファイルサイズ表示 -->
                    <Grid Grid.Row="0" Margin="5,5,5,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- ファイル名表示 -->
                        <TextBlock Grid.Row="0" x:Name="FileNameDisplay" 
                                 Text="ファイルが選択されていません" 
                                 FontWeight="Bold"
                                 Foreground="DarkBlue"
                                 TextWrapping="Wrap"/>
                        
                        <!-- ファイルサイズ表示 -->
                        <TextBlock Grid.Row="1" x:Name="FileSizeDisplay" 
                                 Text="" 
                                 FontWeight="Bold"
                                 Foreground="DarkBlue"
                                 Visibility="Collapsed"
                                 Margin="0,5,0,0"/>
                    </Grid>
                    
                    <!-- コンピューター名表示 -->
                    <TextBlock Grid.Row="1" x:Name="ComputerNameDisplay" 
                             Text="" 
                             Margin="5,0,5,5" 
                             FontWeight="Bold"
                             Foreground="DarkBlue"
                             TextWrapping="Wrap"
                             Visibility="Collapsed"/>
                    
                    <!-- データ取得間隔表示 -->
                    <TextBlock Grid.Row="2" x:Name="SamplingIntervalDisplay" 
                             Text="" 
                             Margin="5,0,5,10" 
                             FontWeight="Bold"
                             Foreground="DarkBlue"
                             TextWrapping="Wrap"
                             Visibility="Collapsed"/>
                    
                    <!-- パターン選択 -->
                    <StackPanel Grid.Row="3" Margin="5,5,5,10">
                        <TextBlock Text="🎯 カウンターパターン:" 
                                 Margin="0,0,0,3" 
                                 FontWeight="SemiBold"/>
                        <ComboBox x:Name="PatternComboBox" 
                                DisplayMemberPath="Name"
                                SelectionChanged="PatternComboBox_SelectionChanged"
                                ToolTip="事前定義されたカウンターパターンを選択"/>
                        <Button x:Name="ApplyPatternButton" 
                              Content="パターンを適用" 
                              Margin="0,3,0,0" 
                              Click="ApplyPattern_Click"
                              IsEnabled="False"
                              ToolTip="選択されたパターンでカウンターを自動選択します"/>
                    </StackPanel>
                    
                    <!-- 時間範囲選択 -->
                    <Expander Grid.Row="4" Header="📅 時間範囲選択" IsExpanded="False" Margin="5,5,5,5"
                             x:Name="TimeRangeExpander" Visibility="Collapsed">
                        <StackPanel Margin="10">
                            <TextBlock Text="時間範囲:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TimeRangeDisplay" Text="時間範囲が検出されていません" Margin="0,0,0,10" FontSize="11" Foreground="DarkGray"/>
                            
                            <Grid Margin="0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 開始時間スライダー -->
                                <StackPanel Grid.Row="0" Margin="0,0,0,5">
                                    <TextBlock Text="開始時間:" FontSize="11" Margin="0,0,0,2"/>
                                    <Slider x:Name="StartTimeSlider" 
                                           Minimum="0" Maximum="100" Value="0"
                                           ValueChanged="TimeSlider_ValueChanged"
                                           TickPlacement="BottomRight" TickFrequency="10"
                                           IsSnapToTickEnabled="False"/>
                                    <TextBlock x:Name="StartTimeText" Text="--:--:--" FontSize="10" HorizontalAlignment="Left" Foreground="DarkBlue"/>
                                </StackPanel>
                                
                                <!-- 終了時間スライダー -->
                                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                    <TextBlock Text="終了時間:" FontSize="11" Margin="0,0,0,2"/>
                                    <Slider x:Name="EndTimeSlider" 
                                           Minimum="0" Maximum="100" Value="100"
                                           ValueChanged="TimeSlider_ValueChanged"
                                           TickPlacement="BottomRight" TickFrequency="10"
                                           IsSnapToTickEnabled="False"/>
                                    <TextBlock x:Name="EndTimeText" Text="--:--:--" FontSize="10" HorizontalAlignment="Right" Foreground="DarkBlue"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Expander>
                    
                    <!-- relog.exe情報表示 -->
                    <Expander Grid.Row="5" Header="📝 relog.exe コマンド" IsExpanded="False" 
                             Margin="5,5,5,5" x:Name="RelogCommandExpander" Visibility="Collapsed">
                        <StackPanel Margin="5">
                            <TextBlock Text="現在の設定の relog.exe コマンド:" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"/>
                            <TextBox x:Name="RelogCommandDisplay" 
                                    IsReadOnly="True" 
                                    Background="LightCyan"
                                    FontFamily="Consolas"
                                    FontSize="10"
                                    TextWrapping="Wrap"
                                    MinHeight="80"
                                    VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Expander>
                    
                    <!-- ボタン群 -->
                    <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                        <Button Content="🚀 選択されたカウンターを読み込み" 
                               AutomationProperties.Name="選択されたカウンターを読み込み"
                               Click="ExecuteSelectedCounters_Click"
                               Background="LightBlue" 
                               Padding="8,4"
                               Margin="0,0,10,0"
                               IsEnabled="False"
                               x:Name="ExecuteButton"/>
                        <Button Content="すべて選択" Click="SelectAll_Click" Margin="0,0,5,0"/>
                        <Button Content="すべて解除" Click="UnselectAll_Click"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="7" 
                             Text="📈 表示したいカウンターをチェック:" 
                             Margin="5,0,5,5" 
                             FontWeight="SemiBold"/>
                    
                    <ScrollViewer Grid.Row="8" VerticalScrollBarVisibility="Auto">
                        <TreeView x:Name="CounterTreeView" Margin="5">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsChecked}" 
                                                IsThreeState="{Binding IsThreeState}"
                                                Checked="CounterCheckBox_Checked"
                                                Unchecked="CounterCheckBox_Unchecked"
                                                Indeterminate="CounterCheckBox_Indeterminate"
                                                Tag="{Binding}"
                                                Visibility="{Binding CheckBoxVisibility}"
                                                Margin="0,0,5,0"/>
                                        <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,3,0"/>
                                        <TextBlock Text="{Binding DisplayName}" 
                                                 Margin="0,0,0,0"
                                                 FontWeight="{Binding FontWeight}"
                                                 Foreground="{Binding TextColor}"/>
                                        <TextBlock Text="{Binding CountDisplay}" 
                                                 Margin="5,0,0,0" 
                                                 FontSize="10" 
                                                 Foreground="Gray"
                                                 Visibility="{Binding CountVisibility}"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>
                </Grid>
            </GroupBox>

            <!-- カウンター選択エリアとグラフ領域の幅調整 -->
            <Grid Grid.Column="1" x:Name="CounterPanelDividerHost">
                <Border Background="#F8F8F8"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1,0,1,0"/>
                <GridSplitter x:Name="CounterPanelGridSplitter"
                              Width="5"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="#E0E0E0"
                              Cursor="SizeWE"
                              ShowsPreview="False"
                              ToolTip="ドラッグしてカウンター選択エリアの幅を調整">
                    <GridSplitter.Style>
                        <Style TargetType="GridSplitter">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D0D0D0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </GridSplitter.Style>
                </GridSplitter>
                <Button x:Name="CounterPanelToggleButton"
                        Width="16"
                        Height="34"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="CounterPanelVisibilityButton_Click"
                        ToolTip="クリックでカウンター選択エリアの表示/非表示を切り替えます"
                        Padding="0"
                        FontSize="11"
                        Content="◀"
                        Background="White"
                        BorderBrush="#BDBDBD"
                        BorderThickness="1"/>
            </Grid>

            <!-- 中央: グラフ表示 -->
            <GroupBox Grid.Column="2" Header="グラフ表示" Margin="5,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition x:Name="StatisticsAreaRowDefinition" Height="170" MinHeight="80" MaxHeight="450"/>
                    </Grid.RowDefinitions>
                    
                    <!-- グラフタイプ選択と凡例制御 -->
                    <Border Grid.Row="0" Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Margin="5,5,5,0">
                        <Grid Margin="10,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                                <TextBlock Text="Y軸:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                <TextBlock Text="下限" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox x:Name="YAxisMinTextBox"
                                        Width="70"
                                        Text="0"
                                        Margin="0,0,6,0"
                                        VerticalContentAlignment="Center"
                                        KeyDown="YAxisRangeTextBox_KeyDown"
                                        ToolTip="Y軸の下限値"/>
                                <TextBlock Text="上限" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox x:Name="YAxisMaxTextBox"
                                        Width="70"
                                        Text="100"
                                        Margin="0,0,6,0"
                                        VerticalContentAlignment="Center"
                                        KeyDown="YAxisRangeTextBox_KeyDown"
                                        ToolTip="Y軸の上限値"/>
                                <Button x:Name="ApplyYAxisRangeButton"
                                       Content="適用"
                                       Click="ApplyYAxisRange_Click"
                                       Padding="8,4"
                                       Margin="0,0,4,0"
                                       ToolTip="入力したY軸範囲を適用します"/>
                                <Button x:Name="ResetYAxisRangeButton"
                                       Content="自動"
                                       Click="ResetYAxisRange_Click"
                                       Padding="8,4"
                                       ToolTip="Y軸範囲を自動設定に戻します"/>
                            </StackPanel>

                            <!-- グラフタイプ選択 -->
                             <StackPanel Grid.Column="1" Orientation="Horizontal">
                                  <TextBlock Text="📊 グラフタイプ:" 
                                           VerticalAlignment="Center" 
                                           FontWeight="SemiBold" 
                                           Margin="0,0,15,0"/>
                                <RadioButton x:Name="LineChartRadio" 
                                           Content="折れ線グラフ" 
                                           IsChecked="True" 
                                           GroupName="ChartType"
                                           Checked="ChartType_Changed"
                                           Margin="0,0,20,0"
                                           VerticalAlignment="Center"/>
                                 <RadioButton x:Name="StackedAreaChartRadio" 
                                            Content="積み重ね面グラフ" 
                                            GroupName="ChartType"
                                            Checked="ChartType_Changed"
                                            VerticalAlignment="Center"/>
                             </StackPanel>
                            
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0,0,0">
                                <TextBlock Text="📉 値モード:" 
                                         VerticalAlignment="Center" 
                                         FontWeight="SemiBold" 
                                         Margin="0,0,15,0"/>
                                <RadioButton x:Name="RawValueModeRadio" 
                                           Content="生値" 
                                           IsChecked="True"
                                           GroupName="ValueMode"
                                           Checked="ValueMode_Changed"
                                           Margin="0,0,20,0"
                                           VerticalAlignment="Center"/>
                                <RadioButton x:Name="DeltaValueModeRadio" 
                                           Content="前回差分" 
                                           GroupName="ValueMode"
                                           Checked="ValueMode_Changed"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- グラフと凡例の表示エリア -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5" x:Name="LegendSplitterColumn"/>
                            <ColumnDefinition Width="250" MinWidth="150" MaxWidth="400" x:Name="LegendColumn"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- ScottPlot グラフコンテナ（リサイズハンドル付き） -->
                        <Border Grid.Column="0" x:Name="GraphContainer" Background="Transparent">
                            <Grid>
                                <scottplot:WpfPlot x:Name="PerformanceChart" 
                                                  Background="White">
                                    <scottplot:WpfPlot.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="グラフをクリップボードにコピー(_C)" 
                                                     Click="CopyGraphToClipboard_Click"
                                                     InputGestureText="Ctrl+C"
                                                     x:Name="ContextMenuCopyGraph">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="📋"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </scottplot:WpfPlot.ContextMenu>
                                </scottplot:WpfPlot>
                                
                                <!-- リサイズハンドル（右下角） -->
                                <Border x:Name="ResizeHandle" 
                                        Width="15" Height="15"
                                        HorizontalAlignment="Right" 
                                        VerticalAlignment="Bottom"
                                        Background="LightGray" 
                                        BorderBrush="Gray" 
                                        BorderThickness="1"
                                        Cursor="SizeNWSE"
                                        Opacity="0.7"
                                        ToolTip="ドラッグしてグラフサイズを変更"
                                        Visibility="Collapsed">
                                    <TextBlock Text="⤡" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" 
                                               FontSize="10" 
                                               Foreground="DarkGray"/>
                                </Border>
                            </Grid>
                        </Border>
                        
                        <!-- グリッドスプリッター -->
                        <GridSplitter Grid.Column="1" 
                                      x:Name="LegendGridSplitter"
                                      Width="5" 
                                      HorizontalAlignment="Stretch" 
                                      VerticalAlignment="Stretch"
                                      Background="#E0E0E0"
                                      BorderBrush="#CCCCCC"
                                      BorderThickness="1,0,1,0"
                                      Cursor="SizeWE"
                                      ShowsPreview="False"
                                      ToolTip="ドラッグして凡例領域の幅を調整"
                                      Visibility="Visible">
                            <GridSplitter.Style>
                                <Style TargetType="GridSplitter">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D0D0D0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </GridSplitter.Style>
                        </GridSplitter>
                        
                        <!-- 凡例表示エリア -->
                        <GroupBox Grid.Column="2" 
                                  x:Name="LegendGroupBox"
                                  Header="📋 凡例"
                                  Visibility="Visible"
                                  Background="White">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 凡例操作ボタン -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5" HorizontalAlignment="Right">
                                    <Button x:Name="ShowAllSeriesButton" 
                                           Content="すべて表示"
                                           Click="ShowAllSeries_Click"
                                           Padding="6,2"
                                           Margin="0,0,5,0"
                                           FontSize="10"
                                           ToolTip="すべてのシリーズを表示します"/>
                                    <Button x:Name="HideAllSeriesButton" 
                                           Content="すべて非表示"
                                           Click="HideAllSeries_Click"
                                           Padding="6,2"
                                           FontSize="10"
                                           ToolTip="すべてのシリーズを非表示にします"/>
                                </StackPanel>
                                
                                <!-- 凡例リスト -->
                                <ScrollViewer Grid.Row="1" 
                                              VerticalScrollBarVisibility="Auto" 
                                              HorizontalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="LegendItemsControl" Margin="5">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#E0E0E0" 
                                                        BorderThickness="0,0,0,1" 
                                                        Padding="5"
                                                        Background="{Binding BackgroundBrush}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="20"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <!-- 表示/非表示チェックボックス -->
                                                        <CheckBox Grid.Column="0"
                                                                  IsChecked="{Binding IsVisible}"
                                                                  Checked="LegendItem_Checked"
                                                                  Unchecked="LegendItem_Unchecked"
                                                                  Tag="{Binding CounterPath}"
                                                                  VerticalAlignment="Center"
                                                                  ToolTip="シリーズの表示/非表示を切り替えます"/>
                                                        
                                                        <!-- 色見本 -->
                                                        <Rectangle Grid.Column="1"
                                                                   Width="16" Height="3"
                                                                   Fill="{Binding ColorBrush}"
                                                                   Margin="5,0"
                                                                   VerticalAlignment="Center"/>
                                                        
                                                        <!-- カウンター名 -->
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding CounterName}"
                                                                   TextWrapping="Wrap"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="11"
                                                                   Foreground="{Binding TextBrush}"
                                                                   ToolTip="{Binding CounterPath}"/>
                                                        
                                                        <!-- 現在値 -->
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding CurrentValue}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="DarkBlue"
                                                                   Margin="5,0,0,0"
                                                                   ToolTip="最新の値"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </GroupBox>
                    </Grid>
                    
                    <!-- データなしの場合のメッセージ -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                              x:Name="NoDataMessagePanel" 
                              Visibility="Visible">
                        <TextBlock x:Name="NoDataMessage" 
                                 Text="📊 BLGファイルを開いてカウンターを選択してください"
                                 HorizontalAlignment="Center"
                                 FontSize="16"
                                 Foreground="Gray"
                                 Margin="10"/>
                        <TextBlock HorizontalAlignment="Center" FontSize="12" Foreground="DarkGray" Margin="5">
                            <Run Text="💡 "/>
                            <Run Text="チェックボックス" FontWeight="Bold"/>
                            <Run Text=" または "/>
                            <Run Text="カウンター名" FontWeight="Bold"/>
                            <Run Text="をクリックして詳細データを表示"/>
                        </TextBlock>
                        <TextBlock Text="✨ グラフ機能が実装されました！"
                                 HorizontalAlignment="Center"
                                 FontSize="12"
                                 Foreground="DarkGreen"
                                 FontWeight="Bold"
                                 Margin="5"/>
                    </StackPanel>
                    
                    <!-- グラフ操作ボタン -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5,5,5,0" 
                               x:Name="GraphControlPanel" Visibility="Collapsed">
                        <Button x:Name="ResetZoomButton" 
                               Content="🔄 ズームをリセット" 
                               Click="ResetZoom_Click"
                               Background="#FFF3E0" 
                               BorderBrush="#F57C00"
                               Foreground="#F57C00"
                               Padding="10,5"
                               Margin="5"
                               ToolTip="時間範囲とズーム倍率を初期状態にリセットします"/>
                        <Button x:Name="CopyGraphButton" 
                               Content="📋 グラフをクリップボードにコピー" 
                               Click="CopyGraphToClipboard_Click"
                               Background="#E3F2FD" 
                                BorderBrush="#1976D2"
                                 Foreground="#1976D2"
                                 Padding="10,5"
                                 Margin="5"
                                 ToolTip="現在表示されているグラフを画像としてクリップボードにコピーします"/>
                    </StackPanel>

                    <!-- 統計情報エリアの高さ調整 -->
                    <GridSplitter Grid.Row="3"
                                  x:Name="StatisticsGridSplitter"
                                  Height="5"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="#E0E0E0"
                                  BorderBrush="#CCCCCC"
                                  BorderThickness="0,1,0,1"
                                  Cursor="SizeNS"
                                  ShowsPreview="False"
                                  Visibility="Collapsed"
                                  ToolTip="ドラッグして統計情報エリアの高さを調整">
                        <GridSplitter.Style>
                            <Style TargetType="GridSplitter">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D0D0D0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </GridSplitter.Style>
                    </GridSplitter>
                     
                    <!-- 統計情報表示エリア -->
                    <Border Grid.Row="4" x:Name="StatisticsBorder" 
                           Background="#F8F8F8" 
                           BorderBrush="#E0E0E0" 
                           BorderThickness="0,1,0,0" 
                           Margin="5,0,5,5"
                           Visibility="Collapsed">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- ヘッダー -->
                            <TextBlock Grid.Row="0" 
                                     Text="📊 選択カウンターの統計情報" 
                                     FontWeight="Bold" 
                                     FontSize="12"
                                     Foreground="DarkBlue"
                                     Margin="0,0,0,8"/>
                            
                            <!-- 統計情報テーブル -->
                            <ScrollViewer Grid.Row="1" 
                                        VerticalScrollBarVisibility="Auto" 
                                        HorizontalScrollBarVisibility="Auto">
                                <DataGrid x:Name="StatisticsDataGrid"
                                        AutoGenerateColumns="False"
                                        IsReadOnly="True"
                                        HeadersVisibility="Column"
                                        GridLinesVisibility="Horizontal"
                                        Background="White"
                                        AlternatingRowBackground="#F9F9F9"
                                        BorderThickness="1"
                                        BorderBrush="#DDD"
                                        FontSize="11"
                                        CanUserResizeColumns="True"
                                        CanUserSortColumns="False"
                                        SelectionMode="Single"
                                        Width="Auto"
                                        HorizontalAlignment="Stretch">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="カウンター名" 
                                                           Binding="{Binding CounterName}" 
                                                           Width="300" 
                                                           MinWidth="200"
                                                           MaxWidth="500"
                                                           CanUserResize="True" />
                                        <DataGridTextColumn Header="平均" 
                                                           Binding="{Binding Average}" 
                                                           Width="120"
                                                           MinWidth="80"
                                                           MaxWidth="200"
                                                           CanUserResize="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#008000"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="最大" 
                                                           Binding="{Binding Maximum}" 
                                                           Width="120"
                                                           MinWidth="80"
                                                           MaxWidth="200"
                                                           CanUserResize="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#B40000"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="最小" 
                                                           Binding="{Binding Minimum}" 
                                                           Width="120"
                                                           MinWidth="80"
                                                           MaxWidth="200"
                                                           CanUserResize="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#0000B4"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </GroupBox>

            <!-- グラフ領域とスケール設定領域の幅調整 -->
            <Grid Grid.Column="3" x:Name="ScalePanelDividerHost" Visibility="Collapsed">
                <Border Background="#F8F8F8"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1,0,1,0"/>
                <GridSplitter x:Name="ScalePanelGridSplitter"
                              Width="5"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="#E0E0E0"
                              Cursor="SizeWE"
                              ShowsPreview="False"
                              ToolTip="ドラッグしてスケール設定エリアの幅を調整">
                    <GridSplitter.Style>
                        <Style TargetType="GridSplitter">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D0D0D0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </GridSplitter.Style>
                </GridSplitter>
                <Button x:Name="ScalePanelToggleButton"
                        Width="16"
                        Height="34"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="ScalePanelToggleButton_Click"
                        ToolTip="クリックでスケール設定エリアの表示/非表示を切り替えます"
                        Padding="0"
                        FontSize="11"
                        Content="▶"
                        Background="White"
                        BorderBrush="#BDBDBD"
                        BorderThickness="1"/>
            </Grid>

            <!-- 右側: スケール設定 -->
            <GroupBox Grid.Column="4" Header="スケール設定" x:Name="ScaleControlGroupBox" Visibility="Collapsed" Margin="5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 一括スケール設定 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,5,5,8">
                        <TextBlock Text="一括スケール:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="BulkScaleComboBox" Width="130" Margin="0,0,8,0"
                                 SelectionChanged="BulkScaleComboBox_SelectionChanged"
                                 ToolTip="全カウンターに適用するスケール値を選択"/>
                        <Button Content="全カウンターに適用"
                               Click="ApplyScaleToAllCounters_Click"
                               Padding="10,3"
                               ToolTip="現在表示中の全カウンターへ一括でスケール値を適用します"/>
                    </StackPanel>
                    
                    <!-- カウンタースケール設定リスト -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="CounterScaleStackPanel" Margin="5">
                            <!-- カウンター別スケール設定が動的に追加される -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- GridSplitter: データテーブル領域の高さを動的に変更 -->
        <GridSplitter Grid.Row="3" 
                      Height="5" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch"
                      Background="#E0E0E0"
                      BorderBrush="#CCCCCC"
                      BorderThickness="0,1,0,1"
                      Cursor="SizeNS"
                      ShowsPreview="False"
                      ToolTip="ドラッグしてデータテーブル領域の高さを調整">
            <GridSplitter.Style>
                <Style TargetType="GridSplitter">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#D0D0D0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </GridSplitter.Style>
        </GridSplitter>

        <!-- 下部: データテーブルとログ表示 -->
        <Grid Grid.Row="4" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="700" MinWidth="150"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左側: データテーブル（タブ形式） -->
            <GroupBox Grid.Column="0" Header="📊 データテーブル">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- データテーブルの説明とコントロール -->
                    <Border Grid.Row="0" Margin="5" Background="#F8F8F8" Padding="5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,20,0">
                                <Run Text="📈 カウンター選択方法: "/>
                                <Run Text="チェックボックスをクリック" FontWeight="Bold" Foreground="DarkBlue"/>
                                <Run Text=" または "/>
                                <Run Text="カウンター名をクリック" FontWeight="Bold" Foreground="DarkGreen"/>
                            </TextBlock>
                            <Button Content="すべてのタブを閉じる" 
                                  Click="CloseAllTabs_Click" 
                                  Padding="8,2,8,2"
                                  Margin="0,0,10,0"/>
                            <Button Content="全データをCSV出力" 
                                  Click="ExportAllDataToCsv_Click" 
                                  Padding="8,2,8,2"/>
                        </StackPanel>
                    </Border>
                    
                    <TabControl x:Name="DataTabControl" Grid.Row="1">
                        <!-- データタブは動的に追加される -->
                    </TabControl>
                </Grid>
            </GroupBox>
            
            <!-- 垂直グリッドスプリッター -->
            <GridSplitter Grid.Column="1" 
                          Width="5" 
                          HorizontalAlignment="Stretch" 
                          VerticalAlignment="Stretch"
                          Background="#E0E0E0"
                          BorderBrush="#CCCCCC"
                          BorderThickness="1,0,1,0"
                          Cursor="SizeWE"
                          ShowsPreview="False"
                          ToolTip="ドラッグしてログ表示領域の幅を調整">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>
            
            <!-- 右側: ログ表示 -->
            <GroupBox Grid.Column="2" Header="📋 ログ表示">
                <TabControl x:Name="LogTabControl">
                    <!-- ログタブは動的に追加される -->
                </TabControl>
            </GroupBox>
        </Grid>
        
        <!-- ステータスバー -->
        <StatusBar Grid.Row="5" Background="LightGray" BorderBrush="Gray" BorderThickness="0,1,0,0">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            
            <!-- 左側: ステータステキスト -->
            <StatusBarItem Grid.Column="0">
                <TextBlock x:Name="StatusText" Text="準備完了" FontSize="11" Margin="5,2"/>
            </StatusBarItem>
            
            <!-- 中央左: グラフサイズ表示 -->
            <StatusBarItem Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="GraphSizeText" Text="グラフサイズ: 800×400" FontSize="11" Margin="5,2"
                              MouseLeftButtonDown="GraphSizeText_MouseLeftButtonDown"
                              Cursor="Hand"
                              ToolTip="クリックしてグラフサイズを手動設定"/>
                </StackPanel>
            </StatusBarItem>
            
            <!-- 中央右: セパレーター -->
            <Separator Grid.Column="2" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,2"/>
            
            <!-- 右側: ウィンドウサイズ表示 -->
            <StatusBarItem Grid.Column="3">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="WindowSizeText" Text="ウィンドウサイズ: 1200×800" FontSize="11" Margin="5,2"
                              MouseLeftButtonDown="WindowSizeText_MouseLeftButtonDown"
                              Cursor="Hand"
                              ToolTip="クリックしてウィンドウサイズを手動設定"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
