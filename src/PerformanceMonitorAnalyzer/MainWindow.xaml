<Window x:Class="PerformanceMonitorAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="Performance Monitor Analyzer" Height="800" Width="1200" WindowState="Maximized"
        Icon="Assets/app-icon.ico"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <DataTemplate x:Key="SortableDataGridHeaderTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="SortIndicator"
                           Grid.Column="1"
                           Margin="6,0,0,0"
                           FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridColumnHeader}, Path=SortDirection}"
                             Value="Ascending">
                    <Setter TargetName="SortIndicator" Property="Text" Value="▲"/>
                    <Setter TargetName="SortIndicator" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridColumnHeader}, Path=SortDirection}"
                             Value="Descending">
                    <Setter TargetName="SortIndicator" Property="Text" Value="▼"/>
                    <Setter TargetName="SortIndicator" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition x:Name="BottomPanelDividerRowDefinition" Height="22"/>
            <RowDefinition x:Name="BottomPanelAreaRowDefinition" Height="400" MinHeight="100" MaxHeight="750"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <Border Grid.Row="0" Margin="12,12,12,0" Style="{StaticResource TopBarBorderStyle}">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Right"
                           Text="Performance Monitor Analyzer"
                           Margin="16,0,6,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontWeight="SemiBold"/>
                <Menu VerticalAlignment="Center">
                    <MenuItem Header="ファイル(_F)">
                        <MenuItem Header="BLGファイルを開く(_O)..." Click="OpenBlgFile_Click"/>

                        <Separator/>
                        <MenuItem Header="終了(_X)" Click="Exit_Click"/>
                    </MenuItem>
                    <MenuItem Header="パターン(_P)">
                        <MenuItem x:Name="PatternMenu" Header="カウンターパターンを適用(_A)">
                            <!-- パターンは動的に追加される -->
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="パターン設定ファイルを開く(_O)..." Click="OpenPatternConfig_Click"/>
                        <MenuItem Header="パターン設定を再読み込み(_R)" Click="ReloadPatternConfig_Click"/>
                    </MenuItem>
                    <MenuItem Header="表示(_V)">
                        <MenuItem Header="すべて折りたたむ(_C)" Click="CollapseAllPanelsMenu_Click"/>
                        <MenuItem Header="すべて展開する(_E)" Click="ExpandAllPanelsMenu_Click"/>
                    </MenuItem>
                </Menu>
            </DockPanel>
        </Border>

        <!-- プログレスバー -->
        <Grid Grid.Row="1" x:Name="ProgressGrid" Visibility="Collapsed" Margin="12,8,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.RowSpan="2" Style="{StaticResource InlinePanelBorderStyle}"/>
            <TextBlock Grid.Row="0" x:Name="ProgressStatusText" Text="ファイルを読み込み中..." 
                       Margin="16,14,16,8" FontWeight="Bold"/>
            <Grid Grid.Row="1" Margin="16,0,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0"
                             x:Name="LoadingProgressBar"
                             Margin="0,0,12,0"
                             IsIndeterminate="True"/>
                <Button Grid.Column="1"
                        x:Name="CancelLoadingButton"
                        Content="読み込みを中止"
                        Click="CancelLoadingButton_Click"
                        Style="{StaticResource DangerActionButtonStyle}"
                        Padding="12,4"
                        MinWidth="120"
                        IsEnabled="False"/>
            </Grid>
        </Grid>

        <!-- 上部: カウンター選択とグラフ表示 -->
        <Grid Grid.Row="2" Margin="12,12,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="CounterPanelColumn" Width="440" MinWidth="220"/>
                <ColumnDefinition x:Name="CounterPanelSplitterColumn" Width="22"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="ScalePanelSplitterColumn" Width="22"/>
                <ColumnDefinition x:Name="ScalePanelColumn" Width="230" MinWidth="210"/>
            </Grid.ColumnDefinitions>

            <!-- 左側: カウンター一覧 -->
            <GroupBox Grid.Column="0" x:Name="CounterPanelGroupBox" Header="パフォーマンスカウンター" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ファイル名とファイルサイズ表示 -->
                    <Grid Grid.Row="0" Margin="12,12,12,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- ファイル名表示 -->
                        <TextBlock Grid.Row="0" x:Name="FileNameDisplay" 
                                 Text="ファイルが選択されていません" 
                                 FontWeight="Bold"
                                 Foreground="{StaticResource AccentBrush}"
                                 TextWrapping="Wrap"/>
                        
                        <!-- ファイルサイズ表示 -->
                        <TextBlock Grid.Row="1" x:Name="FileSizeDisplay" 
                                 Text="" 
                                 FontWeight="Bold"
                                 Foreground="{StaticResource AccentBrush}"
                                 Visibility="Collapsed"
                                 Margin="0,5,0,0"/>
                    </Grid>
                    
                    <!-- コンピューター名表示 -->
                    <TextBlock Grid.Row="1" x:Name="ComputerNameDisplay" 
                              Text="" 
                             Margin="12,0,12,6" 
                              FontWeight="Bold"
                              Foreground="{StaticResource AccentBrush}"
                              TextWrapping="Wrap"
                              Visibility="Collapsed"/>
                    
                    <!-- データ取得間隔表示 -->
                    <TextBlock Grid.Row="2" x:Name="SamplingIntervalDisplay" 
                              Text="" 
                             Margin="12,0,12,12" 
                              FontWeight="Bold"
                              Foreground="{StaticResource AccentBrush}"
                              TextWrapping="Wrap"
                              Visibility="Collapsed"/>
                    
                    <!-- パターン選択 -->
                    <StackPanel Grid.Row="3" Margin="12,0,12,12">
                        <TextBlock Text="🎯 カウンターパターン:" 
                                  Margin="0,0,0,3" 
                                  Style="{StaticResource SectionCaptionTextStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="PatternComboBox"
                                      Grid.Column="0"
                                      DisplayMemberPath="Name"
                                      SelectionChanged="PatternComboBox_SelectionChanged"
                                      ToolTip="事前定義されたカウンターパターンを選択"/>
                            <Button x:Name="ApplyPatternButton"
                                    Grid.Column="2"
                                    Content="パターンを適用"
                                    Click="ApplyPattern_Click"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Padding="8,4"
                                    HorizontalAlignment="Left"
                                    IsEnabled="False"
                                    ToolTip="選択されたパターンでカウンターを自動選択します"/>
                        </Grid>
                    </StackPanel>
                    
                    <!-- 時間範囲選択 -->
                    <Expander Grid.Row="4" Header="📅 時間範囲選択" IsExpanded="False" Margin="12,0,12,10"
                             x:Name="TimeRangeExpander" Visibility="Collapsed">
                        <StackPanel Margin="10">
                            <TextBlock Text="時間範囲:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TimeRangeDisplay" Text="時間範囲が検出されていません" Margin="0,0,0,10" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                            
                            <Grid Margin="0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 開始時間スライダー -->
                                <StackPanel Grid.Row="0" Margin="0,0,0,5">
                                    <TextBlock Text="開始時間:" FontSize="11" Margin="0,0,0,2"/>
                                    <Slider x:Name="StartTimeSlider" 
                                           Minimum="0" Maximum="100" Value="0"
                                           ValueChanged="TimeSlider_ValueChanged"
                                           TickPlacement="BottomRight" TickFrequency="10"
                                           IsSnapToTickEnabled="False"/>
                                    <TextBlock x:Name="StartTimeText" Text="--:--:--" FontSize="10" HorizontalAlignment="Left" Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                                
                                <!-- 終了時間スライダー -->
                                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                    <TextBlock Text="終了時間:" FontSize="11" Margin="0,0,0,2"/>
                                    <Slider x:Name="EndTimeSlider" 
                                           Minimum="0" Maximum="100" Value="100"
                                           ValueChanged="TimeSlider_ValueChanged"
                                           TickPlacement="BottomRight" TickFrequency="10"
                                           IsSnapToTickEnabled="False"/>
                                    <TextBlock x:Name="EndTimeText" Text="--:--:--" FontSize="10" HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Expander>
                    
                    <!-- relog.exe情報表示 -->
                    <Expander Grid.Row="5" Header="📝 relog.exe コマンド" IsExpanded="False" 
                             Margin="12,0,12,10" x:Name="RelogCommandExpander" Visibility="Collapsed">
                        <StackPanel Margin="5">
                            <TextBlock Text="現在の設定の relog.exe コマンド:" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"/>
                            <TextBox x:Name="RelogCommandDisplay" 
                                    IsReadOnly="True" 
                                    Background="{StaticResource SurfaceAltBrush}"
                                    FontFamily="Consolas"
                                    FontSize="10"
                                    TextWrapping="Wrap"
                                    MinHeight="80"
                                    VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Expander>
                    
                    <!-- ボタン群 -->
                    <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Left" Margin="12,0,12,12">
                        <Button x:Name="OpenCounterAddDialogButton"
                                Content="カウンターを追加..."
                                Click="OpenCounterAddDialog_Click"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Padding="8,5"
                                Margin="0,0,10,0"
                                IsEnabled="False"/>
                        <Button Content="すべて解除" Click="UnselectAll_Click" Style="{StaticResource GhostButtonStyle}"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="7"
                             Text="📈 カウンター:"
                             Margin="12,0,12,6"
                             Style="{StaticResource SectionCaptionTextStyle}"/>

                    <Grid Grid.Row="8" x:Name="CounterSelectionControlsPanel" Margin="8,0,8,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,5">
                            <Button HorizontalAlignment="Left"
                                    AutomationProperties.Name="選択されたカウンターを読み込み"
                                    Click="ExecuteSelectedCounters_Click"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Padding="8,4"
                                    IsEnabled="False"
                                    x:Name="ExecuteButton">
                                <TextBlock Text="🚀 選択されたカウンターを読み込み"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                           FontWeight="SemiBold"/>
                            </Button>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="削除(&lt;&lt;)"
                                        Click="RemoveSelectedCounter_Click"
                                        Padding="8,4"
                                        Margin="0,0,5,0"/>
                                <Button Content="クリア"
                                        Click="ClearSelectedCounters_Click"
                                        Padding="8,4"/>
                            </StackPanel>
                        </Grid>

                        <GroupBox Grid.Row="1" Header="追加されたカウンター">
                            <ListView x:Name="SelectedCountersListView"
                                      SelectionMode="Extended"
                                      BorderThickness="0"
                                      Margin="3"
                                      PreviewMouseRightButtonDown="SelectedCountersListView_PreviewMouseRightButtonDown">
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem x:Name="CopySelectedCounterPatternSettingMenuItem"
                                                  Header="カウンター設定をコピー"
                                                  Click="CopySelectedCounterPatternSetting_Click"/>
                                    </ContextMenu>
                                </ListView.ContextMenu>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="オブジェクト" DisplayMemberBinding="{Binding ObjectName}" Width="160"/>
                                        <GridViewColumn Header="カウンター" DisplayMemberBinding="{Binding CounterName}" Width="140"/>
                                        <GridViewColumn Header="インスタンス" DisplayMemberBinding="{Binding InstanceDisplayName}" Width="90"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </GroupBox>
                    </Grid>
                </Grid>
            </GroupBox>

            <!-- カウンター選択エリアとグラフ領域の表示切り替え -->
            <GridSplitter Grid.Column="1"
                          x:Name="CounterPanelGridSplitter"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          Background="Transparent"
                          Cursor="SizeWE"
                          ToolTip="ドラッグでパフォーマンスカウンター領域の幅を変更します"/>

            <Grid Grid.Column="1" x:Name="CounterPanelDividerHost">
                <Border Background="{StaticResource PanelDividerBrush}"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="1,0,1,0"
                        IsHitTestVisible="False"/>
                <Button x:Name="CounterPanelToggleButton"
                        Width="16"
                        Height="34"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="CounterPanelVisibilityButton_Click"
                        ToolTip="クリックでカウンター選択エリアの表示/非表示を切り替えます"
                        Style="{StaticResource DividerToggleButtonStyle}"
                        Content="◀"
                        FontSize="11"/>
            </Grid>

            <!-- 中央: グラフ表示 -->
            <GroupBox Grid.Column="2" Header="グラフ表示" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition x:Name="StatisticsDividerRowDefinition" Height="0"/>
                        <RowDefinition x:Name="StatisticsAreaRowDefinition" Height="170" MinHeight="80" MaxHeight="450"/>
                    </Grid.RowDefinitions>
                    
                    <!-- グラフタイプ選択と凡例制御 -->
                    <Border Grid.Row="0" Style="{StaticResource SectionHeaderBorderStyle}" Margin="12,12,12,0">
                            <Grid Margin="10,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                                <TextBlock Text="Y軸:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                <TextBlock Text="下限" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox x:Name="YAxisMinTextBox"
                                        Width="70"
                                        Text="0"
                                        Margin="0,0,6,0"
                                        VerticalContentAlignment="Center"
                                        KeyDown="YAxisRangeTextBox_KeyDown"
                                        ToolTip="Y軸の下限値"/>
                                <TextBlock Text="上限" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox x:Name="YAxisMaxTextBox"
                                        Width="70"
                                        Text="100"
                                        Margin="0,0,6,0"
                                        VerticalContentAlignment="Center"
                                        KeyDown="YAxisRangeTextBox_KeyDown"
                                        ToolTip="Y軸の上限値"/>
                                 <Button x:Name="ApplyYAxisRangeButton"
                                        Content="適用"
                                        Click="ApplyYAxisRange_Click"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Padding="8,4"
                                        Margin="0,0,4,0"
                                        ToolTip="入力したY軸範囲を適用します"/>
                                 <Button x:Name="ResetYAxisRangeButton"
                                        Content="自動"
                                        Click="ResetYAxisRange_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Padding="8,4"
                                        ToolTip="Y軸範囲を自動設定に戻します"/>
                            </StackPanel>

                            <!-- グラフタイプ選択 -->
                             <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                  <TextBlock Text="📊 グラフタイプ:" 
                                           VerticalAlignment="Center" 
                                           FontWeight="SemiBold" 
                                           Margin="0,0,15,0"/>
                                 <RadioButton x:Name="LineChartRadio" 
                                           Content="折れ線グラフ" 
                                           IsChecked="True" 
                                           GroupName="ChartType"
                                           Checked="ChartType_Changed"
                                           Margin="0,0,20,0"
                                           VerticalAlignment="Center"/>
                                  <RadioButton x:Name="StackedAreaChartRadio" 
                                             Content="積み重ね面グラフ" 
                                             GroupName="ChartType"
                                             Checked="ChartType_Changed"
                                             Margin="0,0,24,0"
                                             VerticalAlignment="Center"/>
                                 <TextBlock Text="📉 値モード:" 
                                          VerticalAlignment="Center" 
                                          FontWeight="SemiBold" 
                                          Margin="0,0,15,0"/>
                                 <RadioButton x:Name="RawValueModeRadio" 
                                            Content="Raw" 
                                            IsChecked="True"
                                            GroupName="ValueMode"
                                            Checked="ValueMode_Changed"
                                            Margin="0,0,20,0"
                                            VerticalAlignment="Center"/>
                                  <RadioButton x:Name="DeltaValueModeRadio" 
                                             Content="差分" 
                                             GroupName="ValueMode"
                                             Checked="ValueMode_Changed"
                                             VerticalAlignment="Center"/>
                             </StackPanel>

                             <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0,0,0">
                                 <Button x:Name="CollapseAllPanelsButton"
                                        Content="すべて折りたたむ"
                                        Click="CollapseAllPanelsMenu_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Padding="8,4"
                                        Margin="0,0,6,0"
                                        ToolTip="トグル対応エリアを一括で折りたたみます"/>
                                 <Button x:Name="ExpandAllPanelsButton"
                                        Content="すべて展開する"
                                        Click="ExpandAllPanelsMenu_Click"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Padding="8,4"
                                        ToolTip="トグル対応エリアを一括で展開します"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- グラフと操作エリア -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- グラフと凡例の表示エリア -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="22" x:Name="LegendSplitterColumn"/>
                                <ColumnDefinition Width="320" MinWidth="150" MaxWidth="400" x:Name="LegendColumn"/>
                            </Grid.ColumnDefinitions>
                        
                        <!-- ScottPlot グラフコンテナ（リサイズハンドル付き） -->
                        <Border Grid.Column="0"
                                x:Name="GraphContainer"
                                Style="{StaticResource CardBorderStyle}"
                                Background="{StaticResource SurfaceBrush}"
                                Margin="12,12,6,12"
                                Padding="12"
                                AllowDrop="True"
                                PreviewDragEnter="GraphContainer_PreviewDragEnter"
                                PreviewDragOver="GraphContainer_PreviewDragOver"
                                PreviewDragLeave="GraphContainer_PreviewDragLeave"
                                PreviewDrop="GraphContainer_PreviewDrop">
                            <Grid>
                                <scottplot:WpfPlot x:Name="PerformanceChart" 
                                                  Background="White">
                                    <scottplot:WpfPlot.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="グラフをクリップボードにコピー(_C)" 
                                                     Click="CopyGraphToClipboard_Click"
                                                     InputGestureText="Ctrl+C"
                                                     x:Name="ContextMenuCopyGraph">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="📋"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </scottplot:WpfPlot.ContextMenu>
                                </scottplot:WpfPlot>

                                <Canvas x:Name="GraphHoverOverlayCanvas"
                                        IsHitTestVisible="False"
                                        Panel.ZIndex="4">
                                    <Border x:Name="GraphHoverContextOverlay"
                                            Visibility="Collapsed"
                                            Background="#F8FFFFFF"
                                            BorderBrush="{StaticResource CardBorderStrongBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,8"
                                            MaxWidth="540">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,6">
                                                <TextBlock x:Name="GraphHoverTimestampText"
                                                           FontWeight="SemiBold"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock x:Name="GraphHoverPinnedIconText"
                                                           Text="📌"
                                                           Visibility="Collapsed"
                                                           FontSize="12"
                                                           Margin="6,0,0,0"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition Width="320"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="1"
                                                           Text="カウンター名"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="値"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Right"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </Grid>
                                            <ScrollViewer MaxHeight="260"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl x:Name="GraphHoverItemsControl">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,0,0,4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="14"/>
                                                                    <ColumnDefinition Width="320"/>
                                                                    <ColumnDefinition Width="120"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0"
                                                                        Width="10"
                                                                        Height="10"
                                                                        CornerRadius="2"
                                                                        VerticalAlignment="Center"
                                                                        Margin="0,3,0,0"
                                                                        Background="{Binding ColorBrush}"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding CounterName}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           ToolTip="{Binding CounterName}"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding CurrentText}"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource AccentBrush}"
                                                                           TextAlignment="Right"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>
                                </Canvas>

                                <Border x:Name="GraphDropOverlay"
                                        Visibility="Collapsed"
                                        IsHitTestVisible="False"
                                        Panel.ZIndex="5"
                                        Margin="2"
                                        CornerRadius="10"
                                        BorderThickness="2"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        Background="#D9EFF8FF">
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Margin="24">
                                        <TextBlock x:Name="GraphDropOverlayIcon"
                                                   Text="📂"
                                                   FontSize="28"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock x:Name="GraphDropOverlayTitle"
                                                   Text="BLG ファイルをドロップして読み込み"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock x:Name="GraphDropOverlayDescription"
                                                   Text=".blg ファイルを 1 つだけドロップできます"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                
                                <!-- リサイズハンドル（右下角） -->
                                <Border x:Name="ResizeHandle" 
                                        Width="15" Height="15"
                                        HorizontalAlignment="Right" 
                                        VerticalAlignment="Bottom"
                                        Panel.ZIndex="6"
                                        Background="{StaticResource SurfaceAltBrush}" 
                                        BorderBrush="{StaticResource CardBorderStrongBrush}" 
                                        BorderThickness="1"
                                        Cursor="SizeNWSE"
                                        Opacity="0.7"
                                        ToolTip="ドラッグしてグラフサイズを変更"
                                        Visibility="Collapsed">
                                    <TextBlock Text="⤡" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" 
                                               FontSize="10" 
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Border>
                            </Grid>
                        </Border>
                        
                        <!-- 凡例領域のドラッグリサイズ用スプリッター（トグルボタンの下に重ねる） -->
                        <GridSplitter Grid.Column="1"
                                      x:Name="LegendGridSplitter"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      ResizeBehavior="PreviousAndNext"
                                      ResizeDirection="Columns"
                                      Background="Transparent"
                                      Cursor="SizeWE"
                                      ToolTip="ドラッグで凡例の幅を変更します"/>

                        <!-- 凡例領域の表示切り替え -->
                        <Grid Grid.Column="1" x:Name="LegendDividerHost" Visibility="Collapsed">
                            <Border Background="{StaticResource PanelDividerBrush}"
                                    BorderBrush="{StaticResource DividerBrush}"
                                    BorderThickness="1,0,1,0"
                                    IsHitTestVisible="False"/>
                            <Button x:Name="LegendPanelToggleButton"
                                    Width="16"
                                    Height="34"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Click="LegendPanelToggleButton_Click"
                                    ToolTip="クリックで凡例の表示/非表示を切り替えます"
                                    Style="{StaticResource DividerToggleButtonStyle}"
                                    Content="▶"
                                    FontSize="11"/>
                        </Grid>
                        
                        <!-- 凡例表示エリア -->
                        <GroupBox Grid.Column="2" 
                                  x:Name="LegendGroupBox"
                                  Header="📋 凡例"
                                  Visibility="Visible"
                                  Background="White"
                                  Margin="6,12,12,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 凡例操作ボタン -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5" HorizontalAlignment="Right">
                                    <Button x:Name="ShowAllSeriesButton" 
                                           Content="すべて表示"
                                           Click="ShowAllSeries_Click"
                                           Style="{StaticResource SuccessActionButtonStyle}"
                                           Padding="6,2"
                                           Margin="0,0,5,0"
                                           FontSize="10"
                                           ToolTip="すべてのシリーズを表示します"/>
                                    <Button x:Name="HideAllSeriesButton" 
                                           Content="すべて非表示"
                                           Click="HideAllSeries_Click"
                                           Style="{StaticResource DangerActionButtonStyle}"
                                           Padding="6,2"
                                           FontSize="10"
                                           ToolTip="すべてのシリーズを非表示にします"/>
                                </StackPanel>
                                
                                <!-- 凡例リスト -->
                                <ScrollViewer Grid.Row="1" 
                                              VerticalScrollBarVisibility="Auto" 
                                              HorizontalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="LegendItemsControl" Margin="5">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource DividerBrush}" 
                                                        BorderThickness="0,0,0,1" 
                                                        Padding="5"
                                                        Background="{Binding BackgroundBrush}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="20"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 折れ線ハイライト -->
                                                        <Button Grid.Column="0"
                                                                Content="{Binding HighlightMark}"
                                                                Click="LegendHighlight_Click"
                                                                Tag="{Binding CounterPath}"
                                                                Width="24"
                                                                Height="20"
                                                                Margin="0,0,6,0"
                                                                Padding="0"
                                                                VerticalAlignment="Center"
                                                                FontWeight="Bold"
                                                                Foreground="{Binding HighlightBrush}"
                                                                ToolTip="折れ線グラフでこの系列を強調表示します"/>
                                                        
                                                        <!-- 表示/非表示チェックボックス -->
                                                        <CheckBox Grid.Column="1"
                                                                  IsChecked="{Binding IsVisible}"
                                                                  Checked="LegendItem_Checked"
                                                                  Unchecked="LegendItem_Unchecked"
                                                                  Tag="{Binding CounterPath}"
                                                                  VerticalAlignment="Center"
                                                                  ToolTip="シリーズの表示/非表示を切り替えます"/>
                                                        
                                                        <!-- 色見本 -->
                                                        <Rectangle Grid.Column="2"
                                                                   Width="16" Height="3"
                                                                   Fill="{Binding ColorBrush}"
                                                                   Margin="5,0"
                                                                   VerticalAlignment="Center"/>
                                                        
                                                        <!-- カウンター名 -->
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding CounterName}"
                                                                   TextWrapping="Wrap"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="10"
                                                                   FontWeight="{Binding CounterFontWeight}"
                                                                   Foreground="{Binding TextBrush}"
                                                                   ToolTip="{Binding CounterPath}"/>

                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </GroupBox>
                        </Grid>
                     
                        <!-- データなしの場合のメッセージ -->
                        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                  x:Name="NoDataMessagePanel" 
                                  Visibility="Visible">
                            <TextBlock x:Name="NoDataMessage" 
                                     Text="📊 BLGファイルを開いてカウンターを選択してください"
                                     HorizontalAlignment="Center"
                                     FontSize="16"
                                     Foreground="{StaticResource TextMutedBrush}"
                                     Margin="10,0,10,4"/>
                            <TextBlock Text="グラフ領域へ .blg ファイルをドラッグアンドドロップして読み込むこともできます"
                                     HorizontalAlignment="Center"
                                     FontSize="12"
                                     Foreground="{StaticResource TextMutedBrush}"
                                     TextAlignment="Center"
                                     TextWrapping="Wrap"
                                     Margin="10,0"/>
                        </StackPanel>
                     
                        <!-- グラフ操作ボタン -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5,5,5,0" 
                                   x:Name="GraphControlPanel" Visibility="Collapsed">
                            <Button x:Name="ResetZoomButton" 
                                   Content="🔄 ズームをリセット" 
                                   Click="ResetZoom_Click"
                                   Style="{StaticResource WarningActionButtonStyle}"
                                   Padding="10,5"
                                   Margin="5"
                                   ToolTip="時間範囲とズーム倍率を初期状態にリセットします"/>
                            <Button x:Name="CopyGraphButton" 
                                   Content="📋 グラフをクリップボードにコピー" 
                                   Click="CopyGraphToClipboard_Click"
                                   Style="{StaticResource SecondaryActionButtonStyle}"
                                   Padding="10,5"
                                   Margin="5"
                                   ToolTip="現在表示されているグラフを画像としてクリップボードにコピーします"/>
                        </StackPanel>
                    </Grid>

                    <!-- 統計情報エリアの高さ調整と表示切り替え -->
                    <Border Grid.Row="2"
                            x:Name="StatisticsDividerBorder"
                            Background="{StaticResource PanelDividerBrush}"
                            BorderBrush="{StaticResource DividerBrush}"
                            BorderThickness="0,1,0,1"
                            Visibility="Collapsed"/>
                    <GridSplitter Grid.Row="2"
                                  x:Name="StatisticsGridSplitter"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="#10D0D0D0"
                                  Cursor="SizeNS"
                                  ShowsPreview="False"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  Visibility="Collapsed"
                                  ToolTip="ドラッグして統計情報エリアの高さを調整"
                                  Panel.ZIndex="1">
                        <GridSplitter.Style>
                            <Style TargetType="GridSplitter">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#20D0D0D0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </GridSplitter.Style>
                    </GridSplitter>
                    <Button Grid.Row="2"
                            x:Name="StatisticsPanelToggleButton"
                            Width="34"
                            Height="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Panel.ZIndex="2"
                            Click="StatisticsPanelToggleButton_Click"
                            ToolTip="クリックで統計情報エリアの表示/非表示を切り替えます"
                            Style="{StaticResource DividerToggleButtonStyle}"
                            Visibility="Collapsed"
                            Content="▲"
                            FontSize="11"/>
                     
                    <!-- 統計情報表示エリア -->
                    <Border Grid.Row="3" x:Name="StatisticsBorder" 
                           Background="{StaticResource SurfaceBrush}" 
                           BorderBrush="{StaticResource CardBorderBrush}" 
                           BorderThickness="1" 
                           CornerRadius="{StaticResource CardCornerRadius}"
                           Margin="5,0,5,5"
                           Visibility="Collapsed">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- ヘッダー -->
                            <TextBlock Grid.Row="0" 
                                     Text="📊 選択カウンターの統計情報" 
                                     FontWeight="Bold" 
                                     FontSize="12"
                                     Foreground="{StaticResource AccentBrush}"
                                     Margin="0,0,0,8"/>
                            
                            <!-- 統計情報テーブル -->
                            <ScrollViewer Grid.Row="1" 
                                        VerticalScrollBarVisibility="Auto" 
                                        HorizontalScrollBarVisibility="Auto">
                                <DataGrid x:Name="StatisticsDataGrid"
                                        AutoGenerateColumns="False"
                                        IsReadOnly="True"
                                        HeadersVisibility="Column"
                                        GridLinesVisibility="Horizontal"
                                        Background="White"
                                        AlternatingRowBackground="#F9F9F9"
                                        BorderThickness="1"
                                        BorderBrush="#DDD"
                                        FontSize="11"
                                        CanUserResizeColumns="True"
                                        CanUserSortColumns="True"
                                        Sorting="StatisticsDataGrid_Sorting"
                                        PreviewMouseRightButtonDown="StatisticsDataGrid_PreviewMouseRightButtonDown"
                                        SelectionMode="Extended"
                                        Width="Auto"
                                        HorizontalAlignment="Stretch">
                                    <DataGrid.Resources>
                                        <Style x:Key="StatisticsCounterCellTextStyle" TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True"/>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style x:Key="StatisticsAverageCellTextStyle" TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#008000"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="TextAlignment" Value="Right"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True"/>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style x:Key="StatisticsMaximumCellTextStyle" TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#B40000"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="TextAlignment" Value="Right"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True"/>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style x:Key="StatisticsMinimumCellTextStyle" TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#0000B4"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="TextAlignment" Value="Right"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsSelected}" Value="True"/>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="選択行をコピー"
                                                      Click="CopySelectedStatisticsRow_Click"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="カウンター名" 
                                                            Binding="{Binding CounterName}" 
                                                            HeaderTemplate="{StaticResource SortableDataGridHeaderTemplate}"
                                                            SortMemberPath="CounterName"
                                                            Width="300" 
                                                            MinWidth="200"
                                                            MaxWidth="500"
                                                            CanUserSort="True"
                                                            CanUserResize="True"
                                                            ElementStyle="{StaticResource StatisticsCounterCellTextStyle}" />
                                        <DataGridTextColumn Header="平均" 
                                                            Binding="{Binding Average}" 
                                                            SortMemberPath="AverageValue"
                                                            HeaderTemplate="{StaticResource SortableDataGridHeaderTemplate}"
                                                            Width="120"
                                                            MinWidth="80"
                                                            MaxWidth="200"
                                                            CanUserResize="True"
                                                            ElementStyle="{StaticResource StatisticsAverageCellTextStyle}"/>
                                        <DataGridTextColumn Header="最大" 
                                                            Binding="{Binding Maximum}" 
                                                            SortMemberPath="MaximumValue"
                                                            HeaderTemplate="{StaticResource SortableDataGridHeaderTemplate}"
                                                            Width="120"
                                                            MinWidth="80"
                                                            MaxWidth="200"
                                                            CanUserResize="True"
                                                            ElementStyle="{StaticResource StatisticsMaximumCellTextStyle}"/>
                                        <DataGridTextColumn Header="最小" 
                                                            Binding="{Binding Minimum}" 
                                                            SortMemberPath="MinimumValue"
                                                            HeaderTemplate="{StaticResource SortableDataGridHeaderTemplate}"
                                                            Width="120"
                                                            MinWidth="80"
                                                            MaxWidth="200"
                                                            CanUserResize="True"
                                                            ElementStyle="{StaticResource StatisticsMinimumCellTextStyle}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </GroupBox>

            <!-- グラフ領域とスケール設定領域の表示切り替え -->
            <GridSplitter Grid.Column="3"
                          x:Name="ScalePanelGridSplitter"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          Background="Transparent"
                          Cursor="SizeWE"
                          IsEnabled="False"
                          ToolTip="ドラッグでスケール設定領域の幅を変更します"/>

            <Grid Grid.Column="3" x:Name="ScalePanelDividerHost" Visibility="Collapsed">
                <Border Background="{StaticResource PanelDividerBrush}"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="1,0,1,0"
                        IsHitTestVisible="False"/>
                <Button x:Name="ScalePanelToggleButton"
                        Width="16"
                        Height="34"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="ScalePanelToggleButton_Click"
                        ToolTip="クリックでスケール設定エリアの表示/非表示を切り替えます"
                        Style="{StaticResource DividerToggleButtonStyle}"
                        Content="▶"
                        FontSize="11"/>
            </Grid>

            <!-- 右側: スケール設定 -->
            <GroupBox Grid.Column="4" Header="スケール設定" x:Name="ScaleControlGroupBox" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 一括スケール設定 -->
                    <StackPanel Grid.Row="0" Margin="5,5,5,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="一括スケール:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="BulkScaleComboBox" Width="130"
                                     SelectionChanged="BulkScaleComboBox_SelectionChanged"
                                     ToolTip="全カウンターに適用するスケール値を選択"/>
                        </StackPanel>
                        <WrapPanel Margin="0,6,0,0">
                            <Button Content="全カウンターに適用"
                                   Click="ApplyScaleToAllCounters_Click"
                                   Style="{StaticResource SecondaryActionButtonStyle}"
                                   Padding="10,3"
                                   Margin="0,0,8,4"
                                   ToolTip="現在表示中の全カウンターへ一括でスケール値を適用します"/>
                            <Button Content="自動スケール"
                                   Click="AutoScaleCounters_Click"
                                   Style="{StaticResource SecondaryActionButtonStyle}"
                                   Padding="10,3"
                                   Margin="0,0,0,4"
                                   ToolTip="表示中カウンターごとに最大絶対値が約 100 になるようスケールを自動設定します"/>
                        </WrapPanel>
                    </StackPanel>
                    
                    <!-- カウンタースケール設定リスト -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="CounterScaleStackPanel" Margin="5">
                            <!-- カウンター別スケール設定が動的に追加される -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- データテーブル / ログ表示エリアの高さ調整と表示切り替え -->
        <Border Grid.Row="3"
                x:Name="BottomPanelDividerBorder"
                Background="{StaticResource PanelDividerBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0,1,0,1"/>
        <GridSplitter Grid.Row="3"
                      x:Name="BottomPanelGridSplitter"
                      Height="22"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#10D0D0D0"
                      BorderBrush="#CCCCCC"
                      BorderThickness="0,1,0,1"
                      Cursor="SizeNS"
                      ShowsPreview="False"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      ToolTip="ドラッグしてデータテーブル / ログ表示エリアの高さを調整"
                      Panel.ZIndex="1">
            <GridSplitter.Style>
                <Style TargetType="GridSplitter">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#20D0D0D0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </GridSplitter.Style>
        </GridSplitter>
        <Button Grid.Row="3"
                x:Name="BottomPanelToggleButton"
                Width="34"
                Height="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Panel.ZIndex="2"
                Click="BottomPanelToggleButton_Click"
                ToolTip="クリックでデータテーブル / ログ表示エリアの表示/非表示を切り替えます"
                Style="{StaticResource DividerToggleButtonStyle}"
                Content="▼"
                FontSize="11"/>

        <!-- 下部: データテーブルとログ表示 -->
        <Grid Grid.Row="4" x:Name="BottomPanelGrid" Margin="12,0,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="700" MinWidth="150"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左側: データテーブル（一覧 + 詳細） -->
            <GroupBox Grid.Column="0" Header="📊 データテーブル" Margin="0,0,8,0">
                <GroupBox.Resources>
                    <Style x:Key="DataTableCounterListBoxItemStyle" TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="Margin" Value="0,0,0,4"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{StaticResource SurfaceAltBrush}"
                                            BorderBrush="{StaticResource DividerBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource SmallCornerRadius}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Stretch"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource CardBorderStrongBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource CardBorderStrongBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </GroupBox.Resources>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="440" MinWidth="180"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="表示中カウンター"
                                           Style="{StaticResource SectionCaptionTextStyle}"/>
                                <ListBox x:Name="DataCounterListBox"
                                         Grid.Row="1"
                                         Margin="0,8,0,0"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="12"
                                         SelectionChanged="DataCounterListBox_SelectionChanged"
                                         ItemContainerStyle="{StaticResource DataTableCounterListBoxItemStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding CounterPath}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Column="1" 
                                      Width="5" 
                                      HorizontalAlignment="Stretch" 
                                      VerticalAlignment="Stretch"
                                      Background="{StaticResource DividerBrush}"
                                      BorderBrush="{StaticResource CardBorderBrush}"
                                      BorderThickness="1,0,1,0"
                                      Cursor="SizeWE"
                                      ShowsPreview="False"
                                      ToolTip="ドラッグして一覧と詳細の幅を調整">
                            <GridSplitter.Style>
                                <Style TargetType="GridSplitter">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D0D0D0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </GridSplitter.Style>
                        </GridSplitter>

                        <Border Grid.Column="2"
                                Margin="8,0,0,0"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                    <TextBlock Text="選択中のデータ"
                                               Style="{StaticResource SectionCaptionTextStyle}"/>
                                    <TextBlock x:Name="SelectedDataCounterTextBlock"
                                               Margin="0,4,0,0"
                                               FontWeight="SemiBold"
                                               Text="表示対象がありません"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Grid Grid.Row="1">
                                    <TextBlock x:Name="DataTableEmptyStateTextBlock"
                                               Text="表示中のデータテーブルはありません。"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"/>
                                    <ContentControl x:Name="DataTableDetailContent"
                                                    Visibility="Collapsed"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </GroupBox>
            
            <!-- 垂直グリッドスプリッター -->
            <GridSplitter Grid.Column="1" 
                          Width="5" 
                          HorizontalAlignment="Stretch" 
                          VerticalAlignment="Stretch"
                          Background="{StaticResource DividerBrush}"
                          BorderBrush="{StaticResource CardBorderBrush}"
                          BorderThickness="1,0,1,0"
                          Cursor="SizeWE"
                          ShowsPreview="False"
                          ToolTip="ドラッグしてログ表示領域の幅を調整">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>
            
            <!-- 右側: ログ表示 -->
            <GroupBox Grid.Column="2" Header="📋 ログ表示" Margin="8,0,0,0">
                <TabControl x:Name="LogTabControl">
                    <!-- ログタブは動的に追加される -->
                </TabControl>
            </GroupBox>
        </Grid>
        
        <!-- ステータスバー -->
        <StatusBar Grid.Row="5" Margin="12,0,12,12">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            
            <!-- 左側: ステータステキスト -->
            <StatusBarItem Grid.Column="0">
                <TextBlock x:Name="StatusText" Text="準備完了" FontSize="11" Margin="5,2"/>
            </StatusBarItem>
            
            <!-- 中央左: グラフサイズ表示 -->
            <StatusBarItem Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="GraphSizeText" Text="グラフサイズ: 800×400" FontSize="11" Margin="5,2"
                              MouseLeftButtonDown="GraphSizeText_MouseLeftButtonDown"
                              Cursor="Hand"
                              ToolTip="クリックしてグラフサイズを手動設定"/>
                </StackPanel>
            </StatusBarItem>
            
            <!-- 中央右: セパレーター -->
            <Separator Grid.Column="2" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,2"/>
            
            <!-- 右側: ウィンドウサイズ表示 -->
            <StatusBarItem Grid.Column="3">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="WindowSizeText" Text="ウィンドウサイズ: 1200×800" FontSize="11" Margin="5,2"
                              MouseLeftButtonDown="WindowSizeText_MouseLeftButtonDown"
                              Cursor="Hand"
                              ToolTip="クリックしてウィンドウサイズを手動設定"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
