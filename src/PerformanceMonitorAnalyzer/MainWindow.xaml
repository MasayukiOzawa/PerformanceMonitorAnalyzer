<Window x:Class="PerformanceMonitorAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="Performance Monitor Analyzer" Height="800" Width="1200" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="550" MinHeight="100" MaxHeight="750"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <Menu Grid.Row="0">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="BLGファイルを開く(_O)..." Click="OpenBlgFile_Click"/>

                <Separator/>
                <MenuItem Header="終了(_X)" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="バージョン情報(_A)"/>
            </MenuItem>
        </Menu>

        <!-- プログレスバー -->
        <Grid Grid.Row="1" x:Name="ProgressGrid" Visibility="Collapsed" Background="#F0F0F0" Margin="10,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" x:Name="ProgressStatusText" Text="ファイルを読み込み中..." 
                       Margin="10,10,10,5" FontWeight="Bold"/>
            <ProgressBar Grid.Row="1" x:Name="LoadingProgressBar" 
                         Height="20" Margin="10,0,10,10" 
                         IsIndeterminate="True"/>
        </Grid>

        <!-- 上部: カウンター選択とグラフ表示 -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側: カウンター一覧 -->
            <GroupBox Grid.Column="0" Header="パフォーマンスカウンター" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ファイル名表示 -->
                    <TextBlock Grid.Row="0" x:Name="FileNameDisplay" 
                             Text="ファイルが選択されていません" 
                             Margin="5,5,5,5" 
                             FontWeight="Bold"
                             Foreground="DarkBlue"
                             TextWrapping="Wrap"/>
                    
                    <!-- コンピューター名表示 -->
                    <TextBlock Grid.Row="0" x:Name="ComputerNameDisplay" 
                             Text="" 
                             Margin="5,25,5,10" 
                             FontSize="11"
                             Foreground="DarkGray"
                             TextWrapping="Wrap"
                             Visibility="Collapsed"/>
                    
                    <TextBlock Grid.Row="1" 
                             Text="📈 表示したいカウンターをチェック:" 
                             Margin="5,0,5,5" 
                             FontWeight="SemiBold"/>
                    
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <TreeView x:Name="CounterTreeView" Margin="5">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsChecked}" 
                                                Checked="CounterCheckBox_Checked"
                                                Unchecked="CounterCheckBox_Unchecked"
                                                Tag="{Binding FullPath}"
                                                Visibility="{Binding CheckBoxVisibility}"
                                                Margin="0,0,5,0"/>
                                        <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,3,0"/>
                                        <TextBlock Text="{Binding DisplayName}" 
                                                 Margin="0,0,0,0"
                                                 FontWeight="{Binding FontWeight}"
                                                 Foreground="{Binding TextColor}"/>
                                        <TextBlock Text="{Binding CountDisplay}" 
                                                 Margin="5,0,0,0" 
                                                 FontSize="10" 
                                                 Foreground="Gray"
                                                 Visibility="{Binding CountVisibility}"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>

                    <!-- 時間範囲選択 -->
                    <Expander Grid.Row="3" Header="📅 時間範囲選択" IsExpanded="False" Margin="5,5,5,0"
                             x:Name="TimeRangeExpander" Visibility="Collapsed">
                        <StackPanel Margin="10">
                            <TextBlock Text="時間範囲:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TimeRangeDisplay" Text="時間範囲が検出されていません" Margin="0,0,0,10" FontSize="11" Foreground="DarkGray"/>
                            
                            <Grid Margin="0,5">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 開始時間スライダー -->
                                <StackPanel Grid.Row="0" Margin="0,0,0,5">
                                    <TextBlock Text="開始時間:" FontSize="11" Margin="0,0,0,2"/>
                                    <Slider x:Name="StartTimeSlider" 
                                           Minimum="0" Maximum="100" Value="0"
                                           ValueChanged="TimeSlider_ValueChanged"
                                           TickPlacement="BottomRight" TickFrequency="10"
                                           IsSnapToTickEnabled="False"/>
                                    <TextBlock x:Name="StartTimeText" Text="--:--:--" FontSize="10" HorizontalAlignment="Left" Foreground="DarkBlue"/>
                                </StackPanel>
                                
                                <!-- 終了時間スライダー -->
                                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                    <TextBlock Text="終了時間:" FontSize="11" Margin="0,0,0,2"/>
                                    <Slider x:Name="EndTimeSlider" 
                                           Minimum="0" Maximum="100" Value="100"
                                           ValueChanged="TimeSlider_ValueChanged"
                                           TickPlacement="BottomRight" TickFrequency="10"
                                           IsSnapToTickEnabled="False"/>
                                    <TextBlock x:Name="EndTimeText" Text="--:--:--" FontSize="10" HorizontalAlignment="Right" Foreground="DarkBlue"/>
                                </StackPanel>
                                
                                <!-- relog.exe実行状況表示 -->
                                <Expander Grid.Row="2" Header="🔧 relog.exe実行状況" IsExpanded="False" 
                                         Margin="0,10,0,0" x:Name="RelogStatusExpander" Visibility="Collapsed">
                                    <StackPanel Margin="5">
                                        <TextBlock Text="実行コマンド:" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                        <TextBox x:Name="RelogCommandDisplay" 
                                                IsReadOnly="True" 
                                                Background="LightYellow"
                                                FontFamily="Consolas"
                                                FontSize="10"
                                                TextWrapping="Wrap"
                                                MinHeight="40"
                                                Margin="0,0,0,10"
                                                VerticalScrollBarVisibility="Auto"/>
                                        
                                        <TextBlock Text="実行結果:" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                        <TextBox x:Name="RelogResultDisplay"
                                                IsReadOnly="True"
                                                Background="LightGray"
                                                FontFamily="Consolas"
                                                FontSize="10"
                                                TextWrapping="Wrap"
                                                MinHeight="60"
                                                VerticalScrollBarVisibility="Auto"/>
                                    </StackPanel>
                                </Expander>
                            </Grid>
                        </StackPanel>
                    </Expander>
                    
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                        <Button Content="🚀 選択されたカウンターを読み込み" 
                               AutomationProperties.Name="選択されたカウンターを読み込み"
                               Click="ExecuteSelectedCounters_Click"
                               Background="LightBlue" 
                               Padding="8,4"
                               Margin="0,0,10,0"
                               IsEnabled="False"
                               x:Name="ExecuteButton"/>
                        <Button Content="すべて選択" Click="SelectAll_Click" Margin="0,0,5,0"/>
                        <Button Content="すべて解除" Click="UnselectAll_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- 右側: グラフ表示 -->
            <GroupBox Grid.Column="1" Header="グラフ表示">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- スケール変更コントロールパネル -->
                    <Border Grid.Row="0" Background="LightBlue" Padding="8,4" 
                            x:Name="ScaleControlPanel" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="カウンター:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox x:Name="CounterScaleComboBox" Width="200" 
                                      VerticalAlignment="Center" Margin="0,0,10,0"
                                      SelectionChanged="CounterScaleComboBox_SelectionChanged"/>
                            <TextBlock Text="スケール:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox x:Name="ScaleValueComboBox" Width="80" 
                                      VerticalAlignment="Center" Margin="0,0,10,0"
                                      SelectionChanged="ScaleValueComboBox_SelectionChanged">
                                <ComboBoxItem Content="1.0" Tag="1.0"/>
                                <ComboBoxItem Content="0.1" Tag="0.1"/>
                                <ComboBoxItem Content="0.01" Tag="0.01"/>
                                <ComboBoxItem Content="0.001" Tag="0.001"/>
                            </ComboBox>
                            <Button Content="適用" Click="ApplyScale_Click" 
                                    Padding="10,2" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- ScottPlot グラフコンテナ -->
                    <scottplot:WpfPlot x:Name="PerformanceChart" 
                                      Grid.Row="1"
                                      Background="White" />
                    
                    <!-- データなしの場合のメッセージ -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                              x:Name="NoDataMessagePanel" 
                              Visibility="Visible">
                        <TextBlock x:Name="NoDataMessage" 
                                 Text="📊 BLGファイルを開いてカウンターを選択してください"
                                 HorizontalAlignment="Center"
                                 FontSize="16"
                                 Foreground="Gray"
                                 Margin="10"/>
                        <TextBlock HorizontalAlignment="Center" FontSize="12" Foreground="DarkGray" Margin="5">
                            <Run Text="💡 "/>
                            <Run Text="チェックボックス" FontWeight="Bold"/>
                            <Run Text=" または "/>
                            <Run Text="カウンター名" FontWeight="Bold"/>
                            <Run Text="をクリックして詳細データを表示"/>
                        </TextBlock>
                        <TextBlock Text="✨ グラフ機能が実装されました！"
                                 HorizontalAlignment="Center"
                                 FontSize="12"
                                 Foreground="DarkGreen"
                                 FontWeight="Bold"
                                 Margin="5"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- GridSplitter: データテーブル領域の高さを動的に変更 -->
        <GridSplitter Grid.Row="3" 
                      Height="5" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch"
                      Background="#E0E0E0"
                      BorderBrush="#CCCCCC"
                      BorderThickness="0,1,0,1"
                      Cursor="SizeNS"
                      ShowsPreview="False"
                      ToolTip="ドラッグしてデータテーブル領域の高さを調整">
            <GridSplitter.Style>
                <Style TargetType="GridSplitter">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#D0D0D0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </GridSplitter.Style>
        </GridSplitter>

        <!-- 下部: データテーブル（タブ形式） -->
        <GroupBox Grid.Row="4" Header="📊 データテーブル" Margin="10,0,10,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- データテーブルの説明とコントロール -->
                <Border Grid.Row="0" Margin="5" Background="#F8F8F8" Padding="5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,20,0">
                            <Run Text="📈 カウンター選択方法: "/>
                            <Run Text="チェックボックスをクリック" FontWeight="Bold" Foreground="DarkBlue"/>
                            <Run Text=" または "/>
                            <Run Text="カウンター名をクリック" FontWeight="Bold" Foreground="DarkGreen"/>
                        </TextBlock>
                        <Button Content="すべてのタブを閉じる" 
                              Click="CloseAllTabs_Click" 
                              Padding="8,2,8,2"
                              Margin="0,0,10,0"/>
                        <Button Content="全データをCSV出力" 
                              Click="ExportAllDataToCsv_Click" 
                              Padding="8,2,8,2"/>
                    </StackPanel>
                </Border>
                
                <TabControl x:Name="DataTabControl" Grid.Row="1">
                    <!-- タブは動的に追加される -->
                </TabControl>
            </Grid>
        </GroupBox>
    </Grid>
</Window>