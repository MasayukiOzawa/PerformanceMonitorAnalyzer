<Window x:Class="PerformanceMonitorAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Performance Monitor Analyzer" Height="800" Width="1200" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="200"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="300" MinHeight="150"/>
        </Grid.RowDefinitions>

        <!-- トースト通知パネル -->
        <Grid x:Name="ToastNotificationPanel" 
              Grid.Row="0" 
              Grid.RowSpan="5" 
              Panel.ZIndex="1000"
              HorizontalAlignment="Right" 
              VerticalAlignment="Top" 
              Margin="20"
              Visibility="Collapsed">
            <Border Background="#333333" 
                    CornerRadius="8" 
                    Padding="15,10"
                    MaxWidth="400"
                    Effect="{DynamicResource {x:Static SystemParameters.DropShadowKey}}">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ToastTransform" X="500"/>
                </Border.RenderTransform>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock x:Name="ToastIcon" 
                                 Text="ℹ️" 
                                 FontSize="14" 
                                 Margin="0,0,8,0" 
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="ToastTitle" 
                                 Text="通知" 
                                 FontWeight="Bold" 
                                 Foreground="White" 
                                 FontSize="14"
                                 VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="ToastMessage" 
                             Text="メッセージ" 
                             Foreground="#E0E0E0" 
                             FontSize="12"
                             TextWrapping="Wrap"
                             LineHeight="16"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- メニューバー -->
        <Menu Grid.Row="0" Panel.ZIndex="10">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="BLGファイルを開く(_O)..." Click="OpenBlgFile_Click"/>

                <Separator/>
                <MenuItem Header="終了(_X)" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="バージョン情報(_A)"/>
            </MenuItem>
        </Menu>

        <!-- プログレスバー -->
        <Grid Grid.Row="1" x:Name="ProgressGrid" Visibility="Collapsed" Background="#F0F0F0" Margin="10,5" Panel.ZIndex="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" x:Name="ProgressStatusText" Text="ファイルを読み込み中..." 
                       Margin="10,10,10,5" FontWeight="Bold"/>
            <ProgressBar Grid.Row="1" x:Name="LoadingProgressBar" 
                         Height="20" Margin="10,0,10,10" 
                         IsIndeterminate="True"/>
        </Grid>

        <!-- 上部: カウンター選択とグラフ表示 -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" MinWidth="250"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- 左側: カウンター一覧 -->
            <GroupBox Grid.Column="0" Header="パフォーマンスカウンター">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ファイル名表示 -->
                    <TextBlock Grid.Row="0" x:Name="FileNameDisplay" 
                             Text="ファイルが選択されていません" 
                             Margin="5,5,5,10" 
                             FontWeight="Bold"
                             Foreground="DarkBlue"
                             TextWrapping="Wrap"/>
                    
                    <TextBlock Grid.Row="1" 
                             Text="📈 表示したいカウンターをチェック:" 
                             Margin="5,0,5,5" 
                             FontWeight="SemiBold"/>
                    
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <TreeView x:Name="CounterTreeView" Margin="5">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsChecked}" 
                                                Checked="CounterCheckBox_Checked"
                                                Unchecked="CounterCheckBox_Unchecked"
                                                Tag="{Binding FullPath}"
                                                Visibility="{Binding CheckBoxVisibility}"
                                                Margin="0,0,5,0"/>
                                        <Image Source="{Binding Icon}" Width="16" Height="16" Margin="0,0,3,0"/>
                                        <TextBlock Text="{Binding DisplayName}" 
                                                 Margin="0,0,0,0"
                                                 FontWeight="{Binding FontWeight}"
                                                 Foreground="{Binding TextColor}"/>
                                        <TextBlock Text="{Binding CountDisplay}" 
                                                 Margin="5,0,0,0" 
                                                 FontSize="10" 
                                                 Foreground="Gray"
                                                 Visibility="{Binding CountVisibility}"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                        <Button Content="すべて選択" Click="SelectAll_Click" Margin="0,0,5,0"/>
                        <Button Content="すべて解除" Click="UnselectAll_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- 水平方向のスプリッター -->
            <GridSplitter Grid.Column="1" 
                         Width="5" 
                         HorizontalAlignment="Stretch" 
                         VerticalAlignment="Stretch"
                         Background="LightGray"
                         ShowsPreview="True"/>

            <!-- 右側: グラフ表示 -->
            <GroupBox Grid.Column="2" Header="グラフ表示">
                <Grid>
                    <Grid x:Name="PerformanceChart" Background="White" />
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="NoDataMessage" 
                                 Text="📊 BLGファイルを開いてカウンターを選択してください"
                                 HorizontalAlignment="Center"
                                 FontSize="16"
                                 Foreground="Gray"
                                 Margin="10"/>
                        <TextBlock HorizontalAlignment="Center" FontSize="12" Foreground="DarkGray" Margin="5">
                            <Run Text="💡 "/>
                            <Run Text="チェックボックス" FontWeight="Bold"/>
                            <Run Text=" または "/>
                            <Run Text="カウンター名" FontWeight="Bold"/>
                            <Run Text="をクリックして詳細データを表示"/>
                        </TextBlock>
                        <TextBlock Text="※グラフ機能は現在開発中です（データテーブルで確認可能）"
                                 HorizontalAlignment="Center"
                                 FontSize="11"
                                 Foreground="LightGray"
                                 Margin="5"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- 垂直方向のスプリッター -->
        <GridSplitter Grid.Row="3" 
                     Height="5" 
                     HorizontalAlignment="Stretch" 
                     VerticalAlignment="Stretch"
                     Background="LightGray"
                     ShowsPreview="True"/>

        <!-- 下部: データテーブル（タブ形式） -->
        <GroupBox Grid.Row="4" Header="📊 データテーブル" Margin="10,0,10,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- データテーブルの説明とコントロール -->
                <Border Grid.Row="0" Margin="5" Background="#F8F8F8" Padding="5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,20,0">
                            <Run Text="📈 カウンター選択方法: "/>
                            <Run Text="チェックボックスをクリック" FontWeight="Bold" Foreground="DarkBlue"/>
                            <Run Text=" または "/>
                            <Run Text="カウンター名をクリック" FontWeight="Bold" Foreground="DarkGreen"/>
                        </TextBlock>
                        <Button Content="すべてのタブを閉じる" 
                              Click="CloseAllTabs_Click" 
                              Padding="8,2,8,2"
                              Margin="0,0,10,0"/>
                        <Button Content="全データをCSV出力" 
                              Click="ExportAllDataToCsv_Click" 
                              Padding="8,2,8,2"/>
                    </StackPanel>
                </Border>
                
                <TabControl x:Name="DataTabControl" Grid.Row="1">
                    <!-- タブは動的に追加される -->
                </TabControl>
            </Grid>
        </GroupBox>
    </Grid>
</Window>