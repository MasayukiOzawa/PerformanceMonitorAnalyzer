<Window x:Class="PerformanceMonitorAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="Performance Monitor Analyzer" Height="800" Width="1200" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="300"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <Menu Grid.Row="0">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="BLGファイルを開く(_O)..." Click="OpenBlgFile_Click"/>
                <Separator/>
                <MenuItem Header="終了(_X)" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="バージョン情報(_A)"/>
            </MenuItem>
        </Menu>

        <!-- 上部: カウンター選択とグラフ表示 -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側: カウンター一覧 -->
            <GroupBox Grid.Column="0" Header="パフォーマンスカウンター" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="選択してグラフに表示:" Margin="5"/>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="CounterPanel" Margin="5"/>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                        <Button Content="すべて選択" Click="SelectAll_Click" Margin="0,0,5,0"/>
                        <Button Content="すべて解除" Click="UnselectAll_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- 右側: グラフ表示 -->
            <GroupBox Grid.Column="1" Header="グラフ表示">
                <Grid>
                    <lvc:CartesianChart x:Name="PerformanceChart" 
                                      LegendLocation="Right"
                                      AnimationsSpeed="0:0:0.5"/>
                    <TextBlock x:Name="NoDataMessage" 
                             Text="BLGファイルを開いてカウンターを選択してください"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontSize="16"
                             Foreground="Gray"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- 下部: データテーブル（タブ形式） -->
        <GroupBox Grid.Row="2" Header="データテーブル" Margin="10,0,10,10">
            <TabControl x:Name="DataTabControl">
                <!-- タブは動的に追加される -->
            </TabControl>
        </GroupBox>
    </Grid>
</Window>