<Window x:Class="PerformanceMonitorAnalyzer.GraphSizeSettingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="グラフサイズ設定" Height="300" Width="450"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0" Text="📊 グラフサイズ設定" FontSize="16" FontWeight="Bold" 
                   Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <!-- 現在のサイズ表示 -->
        <GroupBox Grid.Row="1" Header="現在の設定" Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="サイズ:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1" x:Name="CurrentSizeText" Text="800×400" 
                           FontWeight="Bold" Foreground="DarkBlue" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <!-- サイズ指定 -->
        <GroupBox Grid.Row="2" Header="サイズ指定" Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="幅:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="WidthTextBox" Text="800" 
                         VerticalAlignment="Center" Margin="0,0,15,0" Padding="5,3"
                         TextChanged="SizeTextBox_TextChanged"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="高さ:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="0" Grid.Column="3" x:Name="HeightTextBox" Text="400" 
                         VerticalAlignment="Center" Padding="5,3"
                         TextChanged="SizeTextBox_TextChanged"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Text="💡 有効範囲: 幅 200-3840、高さ 150-2160" 
                           FontSize="11" Foreground="Gray" Margin="0,10,0,10" TextWrapping="Wrap"/>

                <!-- プリセットボタン -->
                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Text="プリセット:" 
                           FontWeight="SemiBold" Margin="0,0,0,5"/>
                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,5,0,0">
                    <Button Content="800×400" Click="PresetSize_Click" Tag="800,400" Margin="0,0,5,0" Padding="8,3"/>
                    <Button Content="1000×500" Click="PresetSize_Click" Tag="1000,500" Margin="0,0,5,0" Padding="8,3"/>
                    <Button Content="1200×600" Click="PresetSize_Click" Tag="1200,600" Margin="0,0,5,0" Padding="8,3"/>
                    <Button Content="1400×700" Click="PresetSize_Click" Tag="1400,700" Margin="0,0,5,0" Padding="8,3"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- プレビュー -->
        <GroupBox Grid.Row="3" Header="プレビュー" Margin="0,0,0,15">
            <TextBlock x:Name="PreviewText" Text="新しいサイズ: 800×400" 
                       Margin="10" FontWeight="Bold" Foreground="DarkBlue" HorizontalAlignment="Center"/>
        </GroupBox>

        <!-- 説明 -->
        <StackPanel Grid.Row="4" Margin="0,0,0,15">
            <TextBlock Text="⚠️ 注意事項:" FontWeight="SemiBold" Foreground="DarkRed" Margin="0,0,0,5"/>
            <TextBlock Text="• グラフエリアのサイズを変更すると、レイアウトが調整されます" FontSize="11" Foreground="Gray" Margin="0,0,0,2"/>
            <TextBlock Text="• 極端に小さなサイズは表示に影響する場合があります" FontSize="11" Foreground="Gray" Margin="0,0,0,2"/>
            <TextBlock Text="• 無効な値が入力された場合、現在の値が維持されます" FontSize="11" Foreground="Gray"/>
        </StackPanel>

        <!-- ボタン -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="適用" Click="Apply_Click" IsDefault="True" 
                    Padding="20,8" Margin="0,0,10,0" Background="LightBlue"/>
            <Button Content="キャンセル" Click="Cancel_Click" IsCancel="True" 
                    Padding="20,8"/>
        </StackPanel>
    </Grid>
</Window>