<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F6FB"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#EEF4FF"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#D8E1EE"/>
    <SolidColorBrush x:Key="CardBorderStrongBrush" Color="#BCCBDF"/>
    <SolidColorBrush x:Key="DividerBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="PanelDividerBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#475569"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#DBEAFE"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="#DCFCE7"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="WarningSoftBrush" Color="#FEF3C7"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#FEE2E2"/>
    <SolidColorBrush x:Key="InfoSoftBrush" Color="#E0F2FE"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="#E0ECFF"/>

    <CornerRadius x:Key="CardCornerRadius">18</CornerRadius>
    <CornerRadius x:Key="ControlCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="SmallCornerRadius">10</CornerRadius>
</ResourceDictionary>
