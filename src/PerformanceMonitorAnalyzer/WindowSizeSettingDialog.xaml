<Window x:Class="PerformanceMonitorAnalyzer.WindowSizeSettingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ウィンドウサイズ設定" Height="350" Width="450"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0" Text="🖥️ ウィンドウサイズ設定" FontSize="16" FontWeight="Bold" 
                   Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <!-- 現在のサイズ表示 -->
        <GroupBox Grid.Row="1" Header="現在の設定" Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="サイズ:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="CurrentSizeText" Text="1200×800" 
                           FontWeight="Bold" Foreground="DarkBlue" VerticalAlignment="Center" Margin="0,0,0,5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="状態:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CurrentStateText" Text="通常" 
                           FontWeight="Bold" Foreground="DarkGreen" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <!-- ウィンドウ状態選択 -->
        <GroupBox Grid.Row="2" Header="ウィンドウ状態" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <RadioButton x:Name="NormalStateRadio" Content="🔳 通常" IsChecked="True" 
                           Margin="0,0,0,5" Checked="WindowState_Changed"/>
                <RadioButton x:Name="MaximizedStateRadio" Content="🔲 最大化" 
                           Margin="0,0,0,5" Checked="WindowState_Changed"/>
                <RadioButton x:Name="MinimizedStateRadio" Content="🗕 最小化" 
                           Margin="0,0,0,0" Checked="WindowState_Changed"/>
            </StackPanel>
        </GroupBox>

        <!-- サイズ指定（通常状態の場合のみ） -->
        <GroupBox Grid.Row="3" Header="サイズ指定" x:Name="SizeSettingGroup" Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="幅:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="WidthTextBox" Text="1200" 
                         VerticalAlignment="Center" Margin="0,0,15,0" Padding="5,3"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="高さ:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="0" Grid.Column="3" x:Name="HeightTextBox" Text="800" 
                         VerticalAlignment="Center" Padding="5,3"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Text="💡 有効範囲: 幅 400-3840、高さ 300-2160" 
                           FontSize="11" Foreground="Gray" Margin="0,10,0,10" TextWrapping="Wrap"/>

                <!-- プリセットボタン -->
                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Text="プリセット:" 
                           FontWeight="SemiBold" Margin="0,0,0,5"/>
                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,5,0,0">
                    <Button Content="1024×768" Click="PresetSize_Click" Tag="1024,768" Margin="0,0,5,0" Padding="8,3"/>
                    <Button Content="1280×720" Click="PresetSize_Click" Tag="1280,720" Margin="0,0,5,0" Padding="8,3"/>
                    <Button Content="1366×768" Click="PresetSize_Click" Tag="1366,768" Margin="0,0,5,0" Padding="8,3"/>
                    <Button Content="1920×1080" Click="PresetSize_Click" Tag="1920,1080" Margin="0,0,5,0" Padding="8,3"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- プレビュー -->
        <GroupBox Grid.Row="4" Header="プレビュー" Margin="0,0,0,15">
            <TextBlock x:Name="PreviewText" Text="新しいサイズ: 1200×800 (通常)" 
                       Margin="10" FontWeight="Bold" Foreground="DarkBlue" HorizontalAlignment="Center"/>
        </GroupBox>

        <!-- 説明 -->
        <StackPanel Grid.Row="5" Margin="0,0,0,15">
            <TextBlock Text="⚠️ 注意事項:" FontWeight="SemiBold" Foreground="DarkRed" Margin="0,0,0,5"/>
            <TextBlock Text="• 最大化/最小化を選択した場合、サイズ指定は無視されます" FontSize="11" Foreground="Gray" Margin="0,0,0,2"/>
            <TextBlock Text="• 設定したサイズが画面サイズを超える場合、自動調整されます" FontSize="11" Foreground="Gray" Margin="0,0,0,2"/>
            <TextBlock Text="• 無効な値が入力された場合、現在の値が維持されます" FontSize="11" Foreground="Gray"/>
        </StackPanel>

        <!-- ボタン -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="適用" Click="Apply_Click" IsDefault="True" 
                    Padding="20,8" Margin="0,0,10,0" Background="LightBlue"/>
            <Button Content="キャンセル" Click="Cancel_Click" IsCancel="True" 
                    Padding="20,8"/>
        </StackPanel>
    </Grid>
</Window>