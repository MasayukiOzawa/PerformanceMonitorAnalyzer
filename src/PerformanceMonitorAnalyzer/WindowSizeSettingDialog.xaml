<Window x:Class="PerformanceMonitorAnalyzer.WindowSizeSettingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ウィンドウサイズ設定" Width="430" MinWidth="430" MinHeight="360"
        SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Border Margin="12" Style="{StaticResource CardBorderStyle}" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- タイトル -->
                <TextBlock Grid.Row="0" Text="🖥️ ウィンドウサイズ設定" FontSize="18" FontWeight="Bold" 
                           Margin="0,0,0,18" HorizontalAlignment="Center" Foreground="{StaticResource AccentBrush}"/>

                <!-- 現在のサイズ表示 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,18" HorizontalAlignment="Center">
                    <TextBlock Text="現在: " VerticalAlignment="Center"/>
                    <TextBlock x:Name="CurrentSizeText" Text="1200×800" 
                               FontWeight="Bold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="(" VerticalAlignment="Center"/>
                    <TextBlock x:Name="CurrentStateText" Text="通常" 
                               FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text=")" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- ウィンドウ状態選択 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,18" HorizontalAlignment="Center">
                    <RadioButton x:Name="NormalStateRadio" Content="通常" IsChecked="True" 
                               Margin="0,0,15,0" Checked="WindowState_Changed"/>
                    <RadioButton x:Name="MaximizedStateRadio" Content="最大化" 
                               Margin="0,0,15,0" Checked="WindowState_Changed"/>
                    <RadioButton x:Name="MinimizedStateRadio" Content="最小化" 
                               Margin="0,0,0,0" Checked="WindowState_Changed"/>
                </StackPanel>

                <!-- サイズ指定（通常状態の場合のみ） -->
                <Grid Grid.Row="3" x:Name="SizeSettingGroup" Margin="0,0,0,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="幅:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="WidthTextBox" Text="1200" 
                             VerticalAlignment="Center" Margin="0,0,15,0" Padding="5,3"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="高さ:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Row="0" Grid.Column="3" x:Name="HeightTextBox" Text="800" 
                             VerticalAlignment="Center" Padding="5,3"/>

                    <!-- プリセットボタン -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" 
                                HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Content="1024×768" Click="PresetSize_Click" Tag="1024,768" Margin="2" Padding="6,2" FontSize="10" Style="{StaticResource GhostButtonStyle}"/>
                        <Button Content="1280×720" Click="PresetSize_Click" Tag="1280,720" Margin="2" Padding="6,2" FontSize="10" Style="{StaticResource GhostButtonStyle}"/>
                        <Button Content="1366×768" Click="PresetSize_Click" Tag="1366,768" Margin="2" Padding="6,2" FontSize="10" Style="{StaticResource GhostButtonStyle}"/>
                        <Button Content="1920×1080" Click="PresetSize_Click" Tag="1920,1080" Margin="2" Padding="6,2" FontSize="10" Style="{StaticResource GhostButtonStyle}"/>
                    </StackPanel>
                </Grid>

                <!-- プレビュー -->
                <TextBlock Grid.Row="4"
                           x:Name="PreviewText"
                           Text="新しいサイズ: 1200×800 (通常)"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,6,0,14"/>

                <!-- ボタン -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="適用" Click="Apply_Click" IsDefault="True" 
                            MinWidth="120" Margin="0,0,10,0" Style="{StaticResource SecondaryActionButtonStyle}"/>
                    <Button Content="キャンセル" Click="Cancel_Click" IsCancel="True" 
                            Padding="15,6" Style="{StaticResource GhostButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
