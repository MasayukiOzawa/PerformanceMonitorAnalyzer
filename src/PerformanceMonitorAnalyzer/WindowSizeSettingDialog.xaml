<Window x:Class="PerformanceMonitorAnalyzer.WindowSizeSettingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ウィンドウサイズ設定" Height="280" Width="400"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0" Text="🖥️ ウィンドウサイズ設定" FontSize="14" FontWeight="Bold" 
                   Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <!-- 現在のサイズ表示 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15" HorizontalAlignment="Center">
            <TextBlock Text="現在: " VerticalAlignment="Center"/>
            <TextBlock x:Name="CurrentSizeText" Text="1200×800" 
                       FontWeight="Bold" Foreground="DarkBlue" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBlock Text="(" VerticalAlignment="Center"/>
            <TextBlock x:Name="CurrentStateText" Text="通常" 
                       FontWeight="Bold" Foreground="DarkGreen" VerticalAlignment="Center"/>
            <TextBlock Text=")" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ウィンドウ状態選択 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15" HorizontalAlignment="Center">
            <RadioButton x:Name="NormalStateRadio" Content="通常" IsChecked="True" 
                       Margin="0,0,15,0" Checked="WindowState_Changed"/>
            <RadioButton x:Name="MaximizedStateRadio" Content="最大化" 
                       Margin="0,0,15,0" Checked="WindowState_Changed"/>
            <RadioButton x:Name="MinimizedStateRadio" Content="最小化" 
                       Margin="0,0,0,0" Checked="WindowState_Changed"/>
        </StackPanel>

        <!-- サイズ指定（通常状態の場合のみ） -->
        <Grid Grid.Row="3" x:Name="SizeSettingGroup" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="幅:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="WidthTextBox" Text="1200" 
                     VerticalAlignment="Center" Margin="0,0,15,0" Padding="5,3"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="高さ:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Row="0" Grid.Column="3" x:Name="HeightTextBox" Text="800" 
                     VerticalAlignment="Center" Padding="5,3"/>

            <!-- プリセットボタン -->
            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" 
                        HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="1024×768" Click="PresetSize_Click" Tag="1024,768" Margin="2" Padding="6,2" FontSize="10"/>
                <Button Content="1280×720" Click="PresetSize_Click" Tag="1280,720" Margin="2" Padding="6,2" FontSize="10"/>
                <Button Content="1366×768" Click="PresetSize_Click" Tag="1366,768" Margin="2" Padding="6,2" FontSize="10"/>
                <Button Content="1920×1080" Click="PresetSize_Click" Tag="1920,1080" Margin="2" Padding="6,2" FontSize="10"/>
            </StackPanel>
        </Grid>

        <!-- ボタン -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock x:Name="PreviewText" Text="新しいサイズ: 1200×800 (通常)" 
                       FontWeight="Bold" Foreground="DarkBlue" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button Content="適用" Click="Apply_Click" IsDefault="True" 
                    Padding="15,6" Margin="0,0,10,0" Background="LightBlue"/>
            <Button Content="キャンセル" Click="Cancel_Click" IsCancel="True" 
                    Padding="15,6"/>
        </StackPanel>
    </Grid>
</Window>