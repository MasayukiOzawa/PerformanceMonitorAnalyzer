<Window x:Class="PerformanceMonitorAnalyzer.CounterAddDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="カウンターを追加"
        Width="820"
        Height="560"
        MinWidth="720"
        MinHeight="460"
        Icon="Assets/app-icon.ico"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Border Margin="12" Style="{StaticResource CardBorderStyle}" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="📈 カウンターを追加"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="オブジェクト、カウンター、インスタンスを選択して追加します。追加後もこの画面から続けて選択できます。"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="オブジェクト" Margin="0,0,8,0">
                        <ListBox x:Name="CounterObjectListBox"
                                 SelectionChanged="CounterObjectListBox_SelectionChanged"
                                 BorderThickness="0"
                                 Margin="3"/>
                    </GroupBox>

                     <GroupBox Grid.Column="1" Header="カウンター" Margin="0,0,8,0">
                         <ListBox x:Name="AvailableCountersListBox"
                                  SelectionMode="Extended"
                                  SelectionChanged="AvailableCountersListBox_SelectionChanged"
                                  BorderThickness="0"
                                  Margin="3">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}"
                                              IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Checked="CounterSelectorCheckBox_Changed"
                                              Unchecked="CounterSelectorCheckBox_Changed"
                                              Tag="{Binding}"
                                              ToolTip="{Binding CounterName}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </GroupBox>

                     <GroupBox Grid.Column="2" x:Name="AvailableInstancesGroupBox" Header="インスタンス">
                         <ListBox x:Name="AvailableInstancesListBox"
                                  SelectionMode="Extended"
                                  IsEnabled="False"
                                  BorderThickness="0"
                                  Margin="3">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}"
                                              IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Checked="CounterSelectorCheckBox_Changed"
                                              Unchecked="CounterSelectorCheckBox_Changed"
                                              Tag="{Binding}"
                                              ToolTip="{Binding InstanceDisplayName}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </GroupBox>
                </Grid>

                <TextBlock Grid.Row="2"
                           x:Name="StatusText"
                           Margin="0,12,0,10"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextWrapping="Wrap"/>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="AddCountersButton"
                            Content="追加"
                            Click="AddCounters_Click"
                            IsDefault="True"
                            MinWidth="120"
                            Margin="0,0,10,0"
                            Style="{StaticResource SecondaryActionButtonStyle}"/>
                    <Button Content="閉じる"
                            Click="Close_Click"
                            IsCancel="True"
                            MinWidth="100"
                            Style="{StaticResource GhostButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
